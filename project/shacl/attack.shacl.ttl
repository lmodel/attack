stix:WindowsPEOptionalHeaderType a sh:NodeShape ;
    rdfs:comment "The Windows PE Optional Header type represents the properties of the PE optional header. At least one property from this type MUST be included." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Specifies the number of data-directory entries in the remainder of the optional header." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path stix:number_of_rva_and_sizes ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the local heap space to reserve." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path stix:size_of_heap_reserve ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the combined size of the MS-DOS, PE header, and section headers, rounded to a multiple of the value specified in file_alignment." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:size_of_headers ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size, in bytes, of the image, including all headers, as the image is loaded in memory." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:size_of_image ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the reserved loader flags." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path stix:loader_flags_hex ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the initialized data section. If there are multiple such sections, this refers to the sum of the sizes of each section." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:size_of_initialized_data ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the alignment (in bytes) of PE sections when they are loaded into memory." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:section_alignment ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the major version number of the required operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:major_os_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the address of the entry point relative to the image base when the executable is loaded into memory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:address_of_entry_point ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the preferred address of the first byte of the image when it is loaded into memory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:image_base ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path stix:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the minor version number of the required operating system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:minor_os_version ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the reserved win32 version value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:win32_version_value_hex ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the subsystem (e.g., GUI, device driver, etc.) that is required to run this image." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:subsystem_hex ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the code (text) section. If there are multiple such sections, this refers to the sum of the sizes of each section." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:size_of_code ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the local heap space to commit." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path stix:size_of_heap_commit ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the major version number of the image." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:major_image_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the minor version number of the subsystem." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:minor_subsystem_version ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the linker minor version number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:minor_linker_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the uninitialized data section. If there are multiple such sections, this refers to the sum of the sizes of each section." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:size_of_uninitialized_data ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the minor version number of the image." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:minor_image_version ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the flags that characterize the PE binary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:dll_characteristics_hex ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the address that is relative to the image base of the beginning-of-code section when it is loaded into memory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:base_of_code ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the stack to reserve." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:size_of_stack_reserve ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the factor (in bytes) that is used to align the raw data of sections in the image file." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:file_alignment ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the checksum of the PE binary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:checksum_hex ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the unsigned integer that indicates the type of the PE binary (e.g. PE32 or PE32+)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:magic_hex ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the stack to commit." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path stix:size_of_stack_commit ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the linker major version number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:major_linker_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the major version number of the subsystem." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:major_subsystem_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the address that is relative to the image base of the beginning-of-data section when it is loaded into memory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:base_of_data ] ;
    sh:targetClass stix:WindowsPEOptionalHeaderType .

stix:WindowsPESection a sh:NodeShape ;
    rdfs:comment "The Windows PE Section type specifies metadata about a PE file section." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies the name of the PE section." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:pe_section_name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
