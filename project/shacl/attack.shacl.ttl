stix:TcpExt a sh:NodeShape ;
    rdfs:comment "The TCP extension specifies a default extension for capturing network traffic properties specific to TCP. Used as the value of the 'tcp-ext' key in a NetworkTraffic object's extensions dictionary." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies the source TCP flags, as the union of all TCP flags observed between the start and end of the session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:src_flags_hex ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the destination TCP flags, as the union of all TCP flags observed between the start and end of the session." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:dst_flags_hex ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:name ] ;
    sh:targetClass stix:TcpExt .

stix:ThreatActor a sh:NodeShape ;
    rdfs:comment "Threat Actors are actual individuals, groups, or organizations believed to be operating with malicious intent. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Threat actor goals." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:goals ],
        [ sh:description "Personal motivations of the threat actor (attack-motivation-ov)." ;
            sh:or ( [ sh:in ( "accidental" "coercion" "dominance" "ideology" "notoriety" "organizational-gain" "personal-gain" "personal-satisfaction" "revenge" "unpredictable" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 10 ;
            sh:path stix:personal_motivations ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:description "Open-vocabulary threat actor categories." ;
            sh:or ( [ sh:in ( "activist" "competitor" "crime-syndicate" "criminal" "hacker" "insider-accidental" "insider-disgruntled" "nation-state" "sensationalist" "spy" "terrorist" "unknown" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path stix:threat_actor_types ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:lang ],
        [ sh:description "Secondary motivations (attack-motivation-ov)." ;
            sh:or ( [ sh:in ( "accidental" "coercion" "dominance" "ideology" "notoriety" "organizational-gain" "personal-gain" "personal-satisfaction" "revenge" "unpredictable" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 9 ;
            sh:path stix:secondary_motivations ],
        [ sh:description "Primary motivation (attack-motivation-ov)." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "accidental" "coercion" "dominance" "ideology" "notoriety" "organizational-gain" "personal-gain" "personal-satisfaction" "revenge" "unpredictable" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 8 ;
            sh:path stix:primary_motivation ],
        [ sh:description "Threat actor resource level (attack-resource-level-ov)." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "individual" "club" "contest" "team" "organization" "government" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 7 ;
            sh:path stix:resource_level ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:dateTime ;
            sh:description "First time observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:first_seen ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Alternative names for the object." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:aliases ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path stix:name ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^threat-actor--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "Open-vocabulary threat actor roles." ;
            sh:or ( [ sh:in ( "agent" "director" "independent" "infrastructure-architect" "infrastructure-operator" "malware-author" "sponsor" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 2 ;
            sh:path stix:roles ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last time observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:last_seen ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^threat-actor$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:labels ],
        [ sh:description "Threat actor sophistication level." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "none" "minimal" "intermediate" "advanced" "expert" "innovator" "strategic" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 6 ;
            sh:path stix:sophistication ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path stix:spec_version ] ;
    sh:targetClass stix:ThreatActor .

stix:Timestamp a sh:NodeShape ;
    rdfs:comment "Represents timestamps across the CTI specifications. The format is an RFC3339 timestamp, with a required timezone specification of 'Z'. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:description ] ;
    sh:targetClass stix:Timestamp .

stix:Tool a sh:NodeShape ;
    rdfs:comment "Tools are legitimate software that can be used by threat actors to perform attacks. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^tool$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:revoked ],
        [ sh:description "Open-vocabulary tool categories (tool-type-ov)." ;
            sh:or ( [ sh:in ( "denial-of-service" "exploitation" "information-gathering" "network-capture" "credential-exploitation" "remote-access" "vulnerability-scanning" "unknown" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 1 ;
            sh:path stix:tool_types ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier for a tool." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:tool_version ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path stix:spec_version ],
        [ sh:class stix:KillChainPhase ;
            sh:description "Kill chain phases associated with this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path stix:kill_chain_phases ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^tool--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Alternative names for the object." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:aliases ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ;
    sh:targetClass stix:Tool .

stix:UnixAccountExt a sh:NodeShape ;
