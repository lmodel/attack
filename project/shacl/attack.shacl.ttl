@prefix attack: <https://w3id.org/lmodel/attack/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix stix: <https://w3id.org/lmodel/stix/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

attack:Analytic a sh:NodeShape ;
    rdfs:comment """Analytics contain the concrete, platform-specific detection logic implementing a Detection Strategy for a specific operating environment. An analytic specifies the exact log data sources to query (via x_mitre_log_source_references), the detection logic or query pattern, and optionally defines tunable parameters (x_mitre_mutable_elements) allowing defenders to adapt it to their environment.
Each analytic targets exactly one platform (x_mitre_platforms maximum cardinality is 1). Multiple analytics may implement the same detection strategy, one per supported platform.
The detection chain is:
  DetectionStrategy (x_mitre_analytic_refs →)
    Analytic (x_mitre_log_source_references →)
      DataComponent (log_source name/channel →)
        detects →
          Technique""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:class attack:LogSourceReference ;
            sh:description "A list of log source references that link this analytic to specific data components and their associated log sources. Each reference identifies a data component by STIX ID and specifies the (name, channel) pair of the log source within that component to target. Each (x_mitre_data_component_ref, name, channel) tuple must be unique within the array." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path attack:x_mitre_log_source_references ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:class attack:MutableElement ;
            sh:description "Environment-tunable parameters within this analytic that defenders can adjust to adapt the detection logic to their specific environment without altering its fundamental detection behavior. Examples include time windows, user context filters, or port ranges. Each element names a tunable field and explains the rationale for tunability." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path attack:x_mitre_mutable_elements ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "A description of this analytic, including what it detects, how it works, and any important behavioral or environmental context." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The name of this analytic." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-analytic$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:description "The single target platform for this analytic. Maximum cardinality is 1; each analytic targets exactly one platform." ;
            sh:in ( "Windows" "Linux" "macOS" "Android" "iOS" "Azure AD" "Google Workspace" "Office Suite" "SaaS" "IaaS" "Containers" "ESXi" "Identity Provider" "Network Devices" "PRE" "None" "Field Controller/RTU/PLC/IED" "Data Historian" "Engineering Workstation" "Control Server" "Human-Machine Interface" "Input/Output Server" "Safety Instrumented System/Protection Relay" "Embedded" ) ;
            sh:order 1 ;
            sh:path attack:x_mitre_platforms ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST contain the analytic's ATT&CK ID as external_id (e.g., 'AN0001')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-analytic--" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ;
    sh:targetClass attack:Analytic .

attack:Asset a sh:NodeShape ;
    rdfs:comment """Assets represent physical or logical systems, devices, and technologies within Operational Technology (OT) and Industrial Control System (ICS) environments that adversaries may target when attacking critical infrastructure. Assets are specific to the ICS ATT&CK domain.
Examples include Programmable Logic Controllers (PLCs), Remote Terminal Units (RTUs), Engineering Workstations, and Safety Instrumented Systems.
Related assets (x_mitre_related_assets) capture sector-specific alias names and variants of the same device type used across different industrial sectors. Asset sectors (x_mitre_sectors) scope the asset to one or more industry verticals.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:class attack:RelatedAsset ;
            sh:description "Sector-specific aliases and related device types associated with this primary asset definition. Related assets describe how the same physical or logical asset may be named or categorized differently across industrial sectors (e.g., a 'Programmable Logic Controller' in manufacturing may be called a 'Field Controller' in water treatment). Each related asset entry may include sector scoping." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path attack:x_mitre_related_assets ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:extensions ],
        [ sh:description "The industry sectors in which this ICS Asset is commonly observed or deployed. Provides context for which operational environments the asset appears in. Only applicable in the ICS ATT&CK domain. At least one sector must be specified when this property is present." ;
            sh:in ( "Electric" "Water and Wastewater" "Manufacturing" "Rail" "Maritime" "General" ) ;
            sh:order 4 ;
            sh:path attack:x_mitre_sectors ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:confidence ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The primary name of the ICS asset (e.g., 'Programmable Logic Controller', 'Data Historian', 'Engineering Workstation')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-asset--" ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path stix:granular_markings ],
        [ sh:description "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted." ;
            sh:in ( "Windows" "Linux" "macOS" "Android" "iOS" "Azure AD" "Google Workspace" "Office Suite" "SaaS" "IaaS" "Containers" "ESXi" "Identity Provider" "Network Devices" "PRE" "None" "Field Controller/RTU/PLC/IED" "Data Historian" "Engineering Workstation" "Control Server" "Human-Machine Interface" "Input/Output Server" "Safety Instrumented System/Protection Relay" "Embedded" ) ;
            sh:order 1 ;
            sh:path attack:x_mitre_platforms ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-asset$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the asset, its function in ICS environments, and its role in industrial process control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the asset's ATT&CK ID as external_id (e.g., 'A0001')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path stix:external_references ] ;
    sh:targetClass attack:Asset .

attack:AttackBundle a sh:NodeShape ;
    rdfs:comment """An ATT&CK STIX Bundle is the top-level distribution container for an ATT&CK domain dataset. ATT&CK publishes one bundle per domain per release:
  - enterprise-attack  (Enterprise ATT&CK)
  - mobile-attack      (Mobile ATT&CK)
  - ics-attack         (ATT&CK for ICS)

A Bundle is NOT a STIX Object — it has no ATT&CK-specific versioning fields, no created_by_ref, and no marking definitions of its own. It serves purely as a JSON container grouping all objects that constitute a release.
ATT&CK Bundle structural requirements:
  1. The bundle MUST contain exactly one x-mitre-collection object.
  2. The x-mitre-collection MUST be the first object in the 'objects' array.
  3. All STIX IDs referenced in the collection's x_mitre_contents MUST be
     present in the bundle's 'objects' array (no dangling references).
  4. No duplicate STIX IDs are permitted within a bundle's objects array.

Note: A STIX Bundle Object is not a STIX Object (Section 7.1, STIX 2.1 spec). Objects within the bundle are not semantically related by virtue of sharing a container; all relationships are expressed via Relationship SRO objects.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The STIX identifier for this bundle. Follows the standard STIX identifier format: bundle--<UUIDv4>." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^bundle--" ],
        [ sh:class stix:StixEntity ;
            sh:description "The ATT&CK STIX objects contained in this bundle. The first object MUST be an x-mitre-collection object. All STIX IDs referenced in the collection's x_mitre_contents must appear as objects in this array." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path stix:bundle_objects ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Must be the literal string 'bundle'." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^bundle$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:name ] ;
    sh:targetClass attack:AttackBundle .

attack:AttackCampaign a sh:NodeShape ;
    rdfs:comment """Campaigns represent a grouping of adversary behaviors and resources with a common objective, occurring over a defined time period. A campaign may be attributed to one or more Groups via 'attributed-to' relationships.
Campaigns require mandatory temporal properties: first_seen and last_seen document when the campaign was active, and the corresponding citation properties (x_mitre_first_seen_citation, x_mitre_last_seen_citation) cite the intelligence sources that established those observations.
The aliases array is required; its first entry MUST match the campaign's name.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "One or more inline citation references documenting the original sources that established when this campaign was last observed. Each citation references a source_name from the object's external_references array. Multiple citations are concatenated without separators: '(Citation: Source1)(Citation: Source2)'. This property is required on all Campaign objects." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_last_seen_citation ;
            sh:pattern "^(\\(Citation:[^)]+\\))+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "The campaign's primary name or identifier (e.g., 'Operation Wocao', 'C0001')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:name ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the campaign, including its objectives, targeted sectors, observed techniques, and any notable characteristics." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^campaign$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:boolean ;
            sh:description "Required on Campaign objects. Indicates whether this campaign has been revoked and superseded by another campaign object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "One or more inline citation references documenting the original sources that established when this campaign was first observed. Each citation references a source_name from the object's external_references array. Multiple citations are concatenated without separators: '(Citation: Source1)(Citation: Source2)'. This property is required on all Campaign objects." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_first_seen_citation ;
            sh:pattern "^(\\(Citation:[^)]+\\))+$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^campaign--" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the campaign's ATT&CK ID as external_id (e.g., 'C0001')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ;
    sh:targetClass attack:AttackCampaign .

attack:AttackIdentity a sh:NodeShape ;
    rdfs:comment """The ATT&CK Identity object represents MITRE Corporation, the organization that maintains the ATT&CK knowledge base. The canonical ATT&CK Identity object has:
  STIX ID: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5
  Name: The MITRE Corporation
  identity_class: organization

This Identity is referenced by created_by_ref and x_mitre_modified_by_ref throughout all ATT&CK objects to attribute creation and modification to MITRE.
Key differences from the standard ATT&CK object:
  - x_mitre_version is absent on Identity objects
  - Several STIX Identity properties (roles, sectors, contact_information) are
    defined in STIX but not actively used in ATT&CK Identity objects""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the identity organization (e.g., 'The MITRE Corporation')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Optional description of the identity organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Not present on ATT&CK Identity objects." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^identity$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:confidence ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:external_references ] ;
    sh:targetClass attack:AttackIdentity .

attack:AttackKillChainPhase a sh:NodeShape ;
    rdfs:comment "An ATT&CK-constrained kill chain phase restricting kill_chain_name to the three ATT&CK domain identifiers: 'mitre-attack', 'mitre-mobile-attack', and 'mitre-ics-attack'. The phase_name must match the x_mitre_shortname of the associated x-mitre-tactic object in the same domain. Used in the kill_chain_phases property of Technique, Malware, and Tool objects to map them to their applicable tactic(s)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The ATT&CK domain kill chain identifier. Must be one of 'mitre-attack', 'mitre-mobile-attack', or 'mitre-ics-attack'." ;
            sh:in ( "mitre-attack" "mitre-mobile-attack" "mitre-ics-attack" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path stix:kill_chain_name ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "The tactic short name corresponding to the x_mitre_shortname of the associated x-mitre-tactic object (e.g., 'initial-access', 'execution')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:phase_name ] ;
    sh:targetClass attack:AttackKillChainPhase .

attack:AttackMalware a sh:NodeShape ;
    rdfs:comment """Malware represents malicious software programs that adversaries use to accomplish their operational objectives, such as data exfiltration, persistent access, lateral movement, or destructive impact. ATT&CK tracks both malware families (is_family: true) and specific malware instances or samples (is_family: false).
Together with Tool objects, Malware forms the ATT&CK 'Software' category. Both share the ATT&CK ID format S#### and are often linked to Groups and Techniques via 'uses' relationships.
The x_mitre_aliases field holds ATT&CK-recognized alternative names; the first alias MUST match the object's name. The STIX 'aliases' property is defined in the STIX specification but is not actively maintained in ATT&CK Malware objects.
Note: Several STIX Malware properties (malware_types, kill_chain_phases, first_seen, last_seen, architecture_execution_envs, implementation_languages, capabilities) are available from the STIX specification but not actively used in ATT&CK.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the malware, its capabilities, how adversaries use it in attacks, and any notable technical characteristics." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the software's ATT&CK ID as external_id (e.g., 'S0001')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^malware$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted." ;
            sh:in ( "Windows" "Linux" "macOS" "Android" "iOS" "Azure AD" "Google Workspace" "Office Suite" "SaaS" "IaaS" "Containers" "ESXi" "Identity Provider" "Network Devices" "PRE" "None" "Field Controller/RTU/PLC/IED" "Data Historian" "Engineering Workstation" "Control Server" "Human-Machine Interface" "Input/Output Server" "Safety Instrumented System/Protection Relay" "Embedded" ) ;
            sh:order 1 ;
            sh:path attack:x_mitre_platforms ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "The primary name of the malware family or instance (e.g., 'Mimikatz', 'WannaCry')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:name ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^malware--" ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "ATT&CK-recognized alternative names or aliases for this software object (Malware or Tool). The first alias in the array MUST match the object's name property. This is the preferred alias field for ATT&CK software objects, distinct from the STIX-standard 'aliases' property which is present but not actively maintained in ATT&CK software objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_aliases ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ] ;
    sh:targetClass attack:AttackMalware .

attack:AttackMarkingDefinition a sh:NodeShape ;
    rdfs:comment """ATT&CK Marking Definition objects apply data handling constraints to ATT&CK content. ATT&CK uses two categories of marking definitions:
1. TLP (Traffic Light Protocol) markings — four canonical instances with fixed IDs:
     TLP:WHITE  → marking-definition--613f2e26-407d-48c7-9eca-b8e91df99dc9
     TLP:GREEN  → marking-definition--34098fce-860f-48ae-8e50-ebd3cc5e41da
     TLP:AMBER  → marking-definition--f88d31f6-486f-44da-b317-01333bde0b82
     TLP:RED    → marking-definition--5e57c739-391a-4eb3-b6be-7d15ca92d5ed

2. Statement markings — copyright and terms-of-use text applied to ATT&CK content.
     Example: "Copyright 2023, The MITRE Corporation. ATT&CK® is a registered trademark."

Marking Definition objects are STIX Meta Objects (SMOs). They do NOT have a 'modified' property and do NOT carry ATT&CK versioning fields (x_mitre_attack_spec_version, x_mitre_version, x_mitre_deprecated).
The canonical TLP marking definition instances MUST NOT be recreated; only the four fixed instances listed above are valid TLP markings for ATT&CK content.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:created ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity that created this marking definition. ATT&CK marking definitions reference MITRE's identity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A statement (e.g., copyright, terms of use) applied to the content marked by this marking definition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:statement ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^marking-definition$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name for TLP marking definitions (e.g., 'TLP:WHITE', 'TLP:GREEN'). Listed in the STIX 2.1 specification; optional in ATT&CK practice." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:name ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^marking-definition--" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^marking-definition--" ],
        [ sh:datatype xsd:string ;
            sh:description "The marking definition payload object. For TLP markings this is a TlpMarkingObject containing the tlp level. For statement markings this is a StatementMarkingObject containing the statement text." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:definition ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:description ],
        [ sh:description "The type of marking definition payload: 'tlp' for Traffic Light Protocol markings, or 'statement' for copyright/terms-of-use text." ;
            sh:in ( "tlp" "statement" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path stix:definition_type ] ;
    sh:targetClass attack:AttackMarkingDefinition .

attack:AttackObject a sh:NodeShape ;
    rdfs:comment "Abstract base class for all versioned ATT&CK objects (SDOs and SROs). Extends the STIX Core (Common Properties) object with ATT&CK-specific universal properties: the required x_mitre_attack_spec_version (which ATT&CK specification the object conforms to), x_mitre_version (the object's content version), and optional x_mitre_deprecated and x_mitre_old_attack_id for lifecycle management. The name property inherited from StixEntity is required on all AttackObject subclasses (except Relationship, where it is not present)." ;
    sh:closed false ;
    sh:ignoredProperties ( attack:x_mitre_last_seen_citation attack:x_mitre_domains attack:x_mitre_is_subtechnique attack:x_mitre_collection_layers attack:x_mitre_analytic_refs attack:x_mitre_aliases attack:x_mitre_network_requirements attack:x_mitre_permissions_required attack:x_mitre_shortname rdf:type attack:x_mitre_remote_support attack:x_mitre_system_requirements attack:x_mitre_log_source_references attack:x_mitre_defense_bypassed attack:tactic_refs attack:x_mitre_contents attack:x_mitre_contributors attack:x_mitre_modified_by_ref attack:x_mitre_impact_type attack:x_mitre_detection attack:x_mitre_log_sources attack:x_mitre_platforms attack:x_mitre_sectors attack:x_mitre_tactic_type attack:x_mitre_effective_permissions attack:x_mitre_first_seen_citation attack:x_mitre_data_sources attack:x_mitre_data_source_ref attack:x_mitre_mutable_elements attack:x_mitre_related_assets ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The human-readable name of this ATT&CK object. Required on all ATT&CK objects except relationship objects (which never carry a name)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ] ;
    sh:targetClass attack:AttackObject .

attack:AttackRelationship a sh:NodeShape ;
    rdfs:comment """ATT&CK Relationship objects connect ATT&CK STIX objects using typed semantic relationships. ATT&CK restricts STIX relationship semantics to a closed set of relationship_type values and enforces valid (source_type, relationship_type, target_type) combinations.
Valid relationship combinations:
  uses:
    malware | tool | intrusion-set | campaign  →  attack-pattern | malware | tool
    (malware→malware and tool→tool combinations are explicitly prohibited)
  mitigates:
    course-of-action  →  attack-pattern
  subtechnique-of:
    attack-pattern  →  attack-pattern  (source=sub-technique, target=parent)
  detects:
    x-mitre-data-component | x-mitre-detection-strategy  →  attack-pattern
    (x-mitre-data-component→attack-pattern DEPRECATED as of Spec 3.3.0)
  attributed-to:
    campaign  →  intrusion-set
  targets:
    attack-pattern  →  x-mitre-asset
  revoked-by:
    <any> → <same STIX type>  (source and target must be the same type)

ATT&CK Relationship objects do not carry a 'name' property or 'x_mitre_version'. The x_mitre_modified_by_ref is required on all ATT&CK relationships.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:revoked ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^relationship--" ],
        [ sh:datatype xsd:string ;
            sh:description "Not present on ATT&CK Relationship objects. Inherited from the base STIX specification but omitted in ATT&CK's use of relationship objects." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:labels ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "Optional human-readable description providing context about this specific relationship instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^relationship$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Not present on ATT&CK Relationship objects. Version tracking is not applied to relationship objects in the ATT&CK Data Model." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ] ;
    sh:targetClass attack:AttackRelationship .

attack:AttackSoftware a sh:NodeShape ;
    rdfs:comment "Abstract superclass for ATT&CK Software objects, representing both Malware and Tool STIX types. Software in ATT&CK encompasses all programs used by adversaries to accomplish their objectives. Both Malware and Tool share the ATT&CK ID format S#### and the same set of ATT&CK-specific properties (x_mitre_aliases, x_mitre_platforms, x_mitre_domains, etc.). Concrete subclasses: Malware (stix type 'malware') and Tool (stix type 'tool')." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type attack:x_mitre_domains attack:x_mitre_platforms attack:x_mitre_aliases attack:x_mitre_contributors attack:x_mitre_modified_by_ref ) ;
    sh:property [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "The human-readable name of this ATT&CK object. Required on all ATT&CK objects except relationship objects (which never carry a name)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:granular_markings ] ;
    sh:targetClass attack:AttackSoftware .

attack:AttackTool a sh:NodeShape ;
    rdfs:comment """Tools represent legitimate software programs that adversaries may abuse or repurpose to accomplish their attack objectives. Unlike Malware, tools are not inherently malicious — they serve legitimate purposes but can be weaponized by adversaries (e.g., Cobalt Strike, Mimikatz, PsExec, Metasploit).
Together with Malware objects, Tools form the ATT&CK 'Software' category and share the same ATT&CK ID format (S####). Both are linked to Groups and Techniques via 'uses' relationships.
The x_mitre_aliases field holds ATT&CK-recognized alternative names; the first alias MUST match the object's name. The STIX 'aliases' property is not actively maintained in ATT&CK Tool objects.
Note: STIX Tool properties (tool_types, kill_chain_phases, tool_version, aliases) are available from the STIX specification but not actively used in ATT&CK Tool objects.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^tool$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:description "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted." ;
            sh:in ( "Windows" "Linux" "macOS" "Android" "iOS" "Azure AD" "Google Workspace" "Office Suite" "SaaS" "IaaS" "Containers" "ESXi" "Identity Provider" "Network Devices" "PRE" "None" "Field Controller/RTU/PLC/IED" "Data Historian" "Engineering Workstation" "Control Server" "Human-Machine Interface" "Input/Output Server" "Safety Instrumented System/Protection Relay" "Embedded" ) ;
            sh:order 1 ;
            sh:path attack:x_mitre_platforms ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path stix:spec_version ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the tool's ATT&CK ID as external_id (e.g., 'S0002')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the tool, its functionality, legitimate uses, and how adversaries leverage it in malicious campaigns." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "The primary name of the tool as used in ATT&CK (e.g., 'Mimikatz', 'PsExec', 'Cobalt Strike')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "ATT&CK-recognized alternative names or aliases for this software object (Malware or Tool). The first alias in the array MUST match the object's name property. This is the preferred alias field for ATT&CK software objects, distinct from the STIX-standard 'aliases' property which is present but not actively maintained in ATT&CK software objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_aliases ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^tool--" ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:revoked ] ;
    sh:targetClass attack:AttackTool .

attack:Collection a sh:NodeShape ;
    rdfs:comment """Collections are versioned snapshots of an ATT&CK dataset grouping all STIX objects that constitute a specific release of an ATT&CK domain or curated subset. ATT&CK distributes one collection per domain per release.
The x_mitre_contents property provides an ordered list of versioned object references (ID + modified timestamp pairs) enumerating every STIX object included in this collection. This precise versioning allows consumers to reconstruct the exact state of the knowledge base at any given ATT&CK release.
Bundle validation: In a distributing STIX Bundle, the Collection must be the first object in the bundle's 'objects' array. All STIX IDs referenced in x_mitre_contents must be present as objects within the same bundle.
See the ATT&CK Workbench collections documentation for detailed design rationale and usage guidance.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class attack:ObjectVersionReference ;
            sh:description "Ordered list of versioned references to all ATT&CK STIX objects included in this collection release." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path attack:x_mitre_contents ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Details, context, and explanation about the purpose, scope, or version of the objects contained in this collection." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-collection--" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "The name of this collection (e.g., 'Enterprise ATT&CK', 'ATT&CK for ICS v14.1')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-collection$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:external_references ] ;
    sh:targetClass attack:Collection .

attack:DataComponent a sh:NodeShape ;
    rdfs:comment """Data Components represent specific types of observable events or artifacts within a Data Source that can be collected to detect adversary technique execution. For example, 'Process Creation' and 'Process Termination' are data components within the 'Process' data source.
Data Components serve as the bridge between defensive telemetry and ATT&CK techniques. They detect techniques via 'detects' relationship objects.
The x_mitre_log_sources property (optional in Spec 3.x, required in Spec 4.x) provides platform-specific log collection configurations specifying exactly which log provider and event channel to monitor.
The x_mitre_data_source_ref property establishing the parent data source link is DEPRECATED in ATT&CK Specification 3.3.0 and will be removed in 4.0.0.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the data component event type (e.g., 'Process Creation', 'Network Traffic Flow', 'File Modification', 'Logon Session Creation')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:name ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-data-component--" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-data-component$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "DEPRECATED. Reference to the parent x-mitre-data-source object. Will be removed in ATT&CK Specification 4.0.0." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_data_source_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-data-source--" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:lang ],
        [ sh:class attack:LogSource ;
            sh:description "Platform-specific log collection configurations for detecting this event type. Optional in ATT&CK Spec 3.x; will become required in Spec 4.x." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path attack:x_mitre_log_sources ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the specific observable event or artifact this data component captures, and how it relates to detecting adversary activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:labels ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path stix:granular_markings ] ;
    sh:targetClass attack:DataComponent .

attack:DataSource a sh:NodeShape ;
    rdfs:comment """DEPRECATED as of ATT&CK Specification 3.3.0. Superseded by the Detection Strategy and Analytic framework. Will be removed in ATT&CK Specification 4.0.0.
Data Sources represented categories of information that could be collected from a computing environment to identify signs of adversary technique execution. They were organized hierarchically: each Data Source contained one or more Data Components specifying observable events within that source category.
The data source hierarchy was:
  DataSource (x-mitre-data-source) →
    DataComponent (x-mitre-data-component) →
      detects →
        Technique (attack-pattern)

Retained for backward compatibility with ATT&CK datasets prior to Spec 3.3.0.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "The technology stack layers from which telemetry for this Data Source can be collected. Indicates where in the environment defenders should look to obtain the raw data this source provides. At least one collection layer must be specified." ;
            sh:in ( "Cloud Control Plane" "Host" "Container" "Network" "Device" "OSINT" "Report" ) ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path attack:x_mitre_collection_layers ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "A description of this data source, the type of information it provides, and how it can be used to detect adversary activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:description ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path stix:spec_version ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the data source's ATT&CK ID as external_id (e.g., 'DS0009')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:external_references ],
        [ sh:description "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted." ;
            sh:in ( "Windows" "Linux" "macOS" "Android" "iOS" "Azure AD" "Google Workspace" "Office Suite" "SaaS" "IaaS" "Containers" "ESXi" "Identity Provider" "Network Devices" "PRE" "None" "Field Controller/RTU/PLC/IED" "Data Historian" "Engineering Workstation" "Control Server" "Human-Machine Interface" "Input/Output Server" "Safety Instrumented System/Protection Relay" "Embedded" ) ;
            sh:order 1 ;
            sh:path attack:x_mitre_platforms ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-data-source$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-data-source--" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the data source category (e.g., 'Process', 'Network Traffic', 'File', 'Windows Registry')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:name ] ;
    sh:targetClass attack:DataSource .

attack:DetectionStrategy a sh:NodeShape ;
    rdfs:comment """Detection Strategies define high-level, platform-agnostic approaches for detecting specific adversary techniques. They function as containers organizing one or more platform-specific Analytics (x-mitre-analytic objects) into cohesive detection methodologies, describing what data to collect and what behavioral patterns to look for.
Detection Strategies were introduced in ATT&CK Specification 3.3.0 as part of the new detection framework, superseding the deprecated x-mitre-data-source and x-mitre-data-component approach for technique detection.
A Detection Strategy links to its implementing analytics via x_mitre_analytic_refs. Analytics in turn link back to data components via x_mitre_log_source_references, creating a complete detection chain from technique to observable log event.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "People and organizations who contributed to this detection strategy. At least one contributor is required on DetectionStrategy objects." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:description ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-detection-strategy--" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX IDs of x-mitre-analytic objects implementing this strategy. Each analytic provides platform-specific detection logic. At least one analytic reference is required; references must be unique." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_analytic_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-analytic--" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:labels ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST contain the detection strategy's ATT&CK ID as external_id (e.g., 'DET0001')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the detection strategy describing the overall detection approach." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:extensions ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-detection-strategy$" ] ;
    sh:targetClass attack:DetectionStrategy .

attack:Group a sh:NodeShape ;
    rdfs:comment """Groups represent clusters of adversary activity attributed to a common actor, sharing characteristics such as tools, tactics, techniques, infrastructure, or targeting. They may represent nation-state actors, criminal organizations, hacktivist collectives, or other tracked threat entities.
Groups are implemented as standard STIX intrusion-set objects without additional ATT&CK-specific custom properties beyond the shared ATT&CK base fields. The aliases array provides alternative names; the first alias MUST match the group's name property.
Note: Several STIX Intrusion Set properties (goals, resource_level, primary_motivation, secondary_motivations, first_seen, last_seen) are inherited from STIX but are not actively used or populated in ATT&CK Group objects.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^intrusion-set$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^intrusion-set--" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "The group's primary name as used in ATT&CK (e.g., 'APT28', 'FIN7', 'Lazarus Group')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:granular_markings ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the group's ATT&CK ID as external_id (e.g., 'G0007')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the group's known activity, targeting preferences, attributed campaigns, and distinguishing characteristics." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:description ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ;
    sh:targetClass attack:Group .

attack:Matrix a sh:NodeShape ;
    rdfs:comment """ATT&CK Matrices define the structural layout and organization of tactics and techniques within each ATT&CK domain. The matrix arranges tactics as columns and techniques (with sub-techniques nested beneath parents) as rows, providing a comprehensive visual map of adversary behavior within a domain.
Each ATT&CK domain has exactly one Matrix object. The tactic_refs property contains an ordered list of x-mitre-tactic STIX IDs that defines the left-to-right display order of columns in the ATT&CK matrix. The matrix does not directly enumerate techniques — technique-to-tactic associations are captured via kill_chain_phases on the Technique objects.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "Ordered list of x-mitre-tactic STIX IDs defining the column order of tactics in this ATT&CK matrix visualization." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:tactic_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-tactic--" ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of this ATT&CK matrix (e.g., 'Enterprise ATT&CK', 'Mobile ATT&CK', 'ICS ATT&CK')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-matrix--" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references for this matrix object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:external_references ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the domain and scope covered by this matrix." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:description ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-matrix$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:extensions ] ;
    sh:targetClass attack:Matrix .

attack:Mitigation a sh:NodeShape ;
    rdfs:comment """Mitigations describe defensive measures, security controls, and configuration changes that can prevent or reduce the effectiveness of adversary techniques. Mitigations are implemented as STIX course-of-action objects.
Historical note — Legacy 1:1 Mitigations: Prior to ATT&CK v5 (July 2019), mitigations had a 1:1 relationship with techniques and shared their ATT&CK IDs. This design was deprecated to support the current many-to-many model where one mitigation can address multiple techniques. Legacy 1:1 mitigation objects may cause ATT&CK ID collisions and can be filtered by their deprecated or revoked status.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path stix:spec_version ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the mitigation (e.g., 'Privileged Account Management', 'Multi-Factor Authentication', 'Network Segmentation')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^course-of-action--" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the mitigation's ATT&CK ID as external_id (e.g., 'M1026')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^course-of-action$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed description of the mitigation, what adversary behaviors it addresses, implementation guidance, and relevant considerations for enterprise defenders." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_old_attack_id ] ;
    sh:targetClass attack:Mitigation .

attack:StatementMarkingObject a sh:NodeShape ;
    rdfs:comment "The definition payload for a statement marking definition. Contains a single statement field with a copyright notice or terms-of-use text. ATT&CK uses this for its standard copyright statement applied to all distributed content." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The full copyright or terms-of-use statement text. Example: \"Copyright 2023, The MITRE Corporation. ATT&CK content is licensed under the Creative Commons Attribution 4.0 International (CC BY 4.0) license.\"" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:statement ] ;
    sh:targetClass attack:StatementMarkingObject .

attack:Tactic a sh:NodeShape ;
    rdfs:comment """Tactics represent the adversary's high-level strategic objectives during an attack — the "why" behind individual techniques. Tactics form the columns of the ATT&CK matrix and organize techniques into coherent operational categories.
Tactics are implemented as x-mitre-tactic custom STIX objects that extend the STIX Domain Object pattern. They are specific to ATT&CK and not defined by the core STIX 2.1 specification.
The x_mitre_shortname property is the machine-readable tactic identifier used to link techniques: a technique's kill_chain_phases entry uses x_mitre_shortname as phase_name when kill_chain_name matches the appropriate ATT&CK domain value.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class stix:ExternalReference ;
            sh:description "External references. The first entry MUST have source_name 'mitre-attack' and contain the tactic's ATT&CK ID as external_id (e.g., 'TA0001')." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "The human-readable name of the tactic (e.g., 'Initial Access', 'Execution', 'Persistence')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:name ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^x-mitre-tactic$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "A full description of the tactic's strategic objective and what adversaries are trying to accomplish by executing techniques in this category." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^x-mitre-tactic--" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:confidence ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:description "The machine-readable short identifier for an ATT&CK tactic. Used to map techniques to their associated tactic: a technique's kill_chain_phases entry uses this value as its phase_name when the kill_chain_name matches the tactic's domain. For example, the 'Initial Access' tactic has x_mitre_shortname 'initial-access'. Must be unique across all tactics within a domain." ;
            sh:in ( "reconnaissance" "resource-development" "initial-access" "execution" "persistence" "privilege-escalation" "defense-evasion" "credential-access" "discovery" "lateral-movement" "collection" "command-and-control" "exfiltration" "impact" "evasion" "network-effects" "remote-service-effects" "inhibit-response-function" "impair-process-control" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path attack:x_mitre_shortname ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ;
    sh:targetClass attack:Tactic .

attack:Technique a sh:NodeShape ;
    rdfs:comment """Techniques describe the specific methods adversaries use to achieve tactical objectives. They are implemented as STIX attack-pattern objects and represent the "how" of adversary behavior — the concrete actions taken to accomplish a tactic.
A Technique may be a top-level technique (x_mitre_is_subtechnique: false) or a sub-technique (x_mitre_is_subtechnique: true). Sub-techniques provide more granular detail about specific implementations of their parent technique.
Sub-technique constraints:
  - ATT&CK ID format: T####.### where T#### is the parent's ID
  - Connected to parent via 'subtechnique-of' relationship (source = sub, target = parent)
  - Each sub-technique has exactly one parent; parents may have many sub-techniques
  - Sub-techniques inherit all parent tactics; platforms must be a subset of parent's

Tactics mapping: kill_chain_phases entries use the tactic's x_mitre_shortname as phase_name, with kill_chain_name set to the appropriate ATT&CK domain value.""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path attack:x_mitre_attack_spec_version ;
            sh:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ],
        [ sh:datatype xsd:string ;
            sh:description "Names of people and organizations who have contributed to the creation or enrichment of this ATT&CK object. Contributors are credited for providing information, examples, or analysis that informed the object's content. Not present on relationship objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path attack:x_mitre_contributors ],
        [ sh:datatype xsd:string ;
            sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. Additional preconditions about the state of the target system that may be required for the technique to succeed, such as required software, configuration settings, patch levels, or service states." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path attack:x_mitre_system_requirements ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^attack-pattern--" ],
        [ sh:datatype xsd:boolean ;
            sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. Boolean indicating whether this technique can be used to execute commands or payloads on a remote system without requiring local presence. When true, the technique supports remote execution scenarios." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path attack:x_mitre_remote_support ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 20 ;
            sh:path stix:spec_version ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path stix:granular_markings ],
        [ sh:description "Indicates whether this technique can be used for availability attacks, integrity attacks, or both. Only applicable to techniques in the Enterprise ATT&CK Impact tactic. A technique with 'Availability' affects the availability of systems or data; 'Integrity' indicates unauthorized modification of data or configuration." ;
            sh:in ( "Availability" "Integrity" ) ;
            sh:order 10 ;
            sh:path attack:x_mitre_impact_type ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the technique or sub-technique (e.g., 'Command and Scripting Interpreter', 'PowerShell')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path stix:lang ],
        [ sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. List of defensive tools, methodologies, or security controls that this technique can bypass, evade, or otherwise circumvent when used by an adversary." ;
            sh:in ( "Signature-based detection" "Signature-based Detection" "Multi-Factor Authentication" "Network Intrusion Detection System" "Network intrusion detection system" "Application Control" "Application control" "Host forensic analysis" "Host Forensic Analysis" "Exploit Prevention" "Data Execution Prevention" "Heuristic Detection" "Heuristic detection" "File system access controls" "File Monitoring" "File monitoring" "Digital Certificate Validation" "Logon Credentials" "Firewall" "Static File Analysis" "Notarization" "System access controls" "System Access Controls" "Binary Analysis" "Web Content Filters" "Host intrusion prevention systems" "Host Intrusion Prevention Systems" "Application whitelisting" "Defensive network service scanning" "User Mode Signature Validation" "Encryption" "Log Analysis" "Log analysis" "Autoruns Analysis" "Anti Virus" "Anti-virus" "Gatekeeper" "Process whitelisting" "Windows User Account Control" "Whitelisting by file name or path" ) ;
            sh:order 5 ;
            sh:path attack:x_mitre_defense_bypassed ],
        [ sh:description "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted." ;
            sh:in ( "Windows" "Linux" "macOS" "Android" "iOS" "Azure AD" "Google Workspace" "Office Suite" "SaaS" "IaaS" "Containers" "ESXi" "Identity Provider" "Network Devices" "PRE" "None" "Field Controller/RTU/PLC/IED" "Data Historian" "Engineering Workstation" "Control Server" "Human-Machine Interface" "Input/Output Server" "Safety Instrumented System/Protection Relay" "Embedded" ) ;
            sh:order 2 ;
            sh:path attack:x_mitre_platforms ],
        [ sh:datatype xsd:string ;
            sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. Narrative text describing analytic strategies that defenders can use to identify whether an adversary has used this technique. Superseded by Detection Strategies and Analytics referenced via 'detects' relationships." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path attack:x_mitre_detection ],
        [ sh:datatype xsd:string ;
            sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. A list of data sources that can provide evidence for detecting this technique. Each entry must follow the format 'Data Source Name: Data Component Name' (e.g., 'Process: Process Creation'). Superseded by 'detects' relationships from x-mitre-data-component and x-mitre-detection-strategy objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path attack:x_mitre_data_sources ],
        [ sh:description "Indicates the adversary's device access model for Mobile ATT&CK techniques. Specifies whether the technique requires post-device-access, pre-device-access, or no device access at all. Only used in the Mobile ATT&CK domain." ;
            sh:in ( "Post-Adversary Device Access" "Pre-Adversary Device Access" "Without Adversary Device Access" ) ;
            sh:order 12 ;
            sh:path attack:x_mitre_tactic_type ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the technique, how adversaries use it, what it accomplishes, and typically includes examples of observed adversary behavior and platform considerations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 34 ;
            sh:path stix:description ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating whether this attack-pattern is a sub-technique (true) or a top-level technique (false). Sub-techniques represent more specific implementations of parent techniques with ATT&CK IDs in the format T####.###. Each sub-technique is connected to its parent via a 'subtechnique-of' relationship where this object is the source_ref and the parent technique is the target_ref. Sub-techniques inherit all of their parent's tactics and must use a subset of the parent's platforms." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path attack:x_mitre_is_subtechnique ],
        [ sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. The lowest permission level at which an adversary must be operating to execute this technique on a target system. If multiple values are present, the technique can be used at any of the listed permission levels." ;
            sh:in ( "Remote Desktop Users" "SYSTEM" "Administrator" "root" "User" ) ;
            sh:order 6 ;
            sh:path attack:x_mitre_permissions_required ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path attack:x_mitre_version ;
            sh:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean indicating whether this technique requires network connectivity as a precondition for execution. When true, the adversary must have network access to the target environment for the technique to be applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path attack:x_mitre_network_requirements ],
        [ sh:description "The ATT&CK technology domains to which this object belongs. At least one domain must be specified. An object may belong to multiple domains when the same technique, group, or software is relevant across domain boundaries." ;
            sh:in ( "enterprise-attack" "mobile-attack" "ics-attack" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:x_mitre_domains ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that first created this ATT&CK object. Typically references MITRE's identity (identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^attack-pattern$" ],
        [ sh:datatype xsd:string ;
            sh:description "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path attack:x_mitre_old_attack_id ],
        [ sh:description "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. The effective permission level(s) that an adversary achieves on the target system after successfully executing this technique. Represents the post-exploitation privilege gain." ;
            sh:in ( "Administrator" "SYSTEM" "User" "root" ) ;
            sh:order 7 ;
            sh:path attack:x_mitre_effective_permissions ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path attack:x_mitre_deprecated ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path attack:x_mitre_modified_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references for this technique. The first entry MUST have source_name 'mitre-attack' with the ATT&CK ID as external_id (e.g., 'T1059' or 'T1059.001'). Additional entries may reference reports, malware analyses, or other sources." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ;
    sh:targetClass attack:Technique .

attack:TlpMarkingObject a sh:NodeShape ;
    rdfs:comment "The definition payload for a TLP (Traffic Light Protocol) marking definition. Contains a single tlp field carrying the TLP level value. Only instances corresponding to the four canonical ATT&CK TLP marking definitions are valid; new TLP marking objects must not be created." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The Traffic Light Protocol level assigned by this TLP marking definition. Must be one of the four standard TLP values: 'white', 'green', 'amber', 'red'. Each TLP level carries distinct sharing semantics governing how marked content may be further distributed by recipients." ;
            sh:in ( "white" "green" "amber" "red" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path attack:tlp ] ;
    sh:targetClass attack:TlpMarkingObject .

stix:ArchiveExt a sh:NodeShape ;
    rdfs:comment "The Archive File extension specifies a default extension for capturing properties specific to archive files, such as ZIP." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "References to contained objects." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:contains_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a comment included as part of the archive file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:comment ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ;
    sh:targetClass stix:ArchiveExt .

stix:Artifact a sh:NodeShape ;
    rdfs:comment "The Artifact Object permits capturing an array of bytes (8-bits), as a base64-encoded string string, or linking to a file-like payload. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^artifact--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Artifact encryption algorithm." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:encryption_algorithm ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Decryption key material." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:decryption_key ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A URL reference to an external resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:url ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Base64 binary payload." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:payload_bin ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^artifact$" ],
        [ sh:class stix:HashesType ;
            sh:description "Specifies a dictionary of hashes for the file or content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path stix:hashes ],
        [ sh:datatype xsd:string ;
            sh:description "MIME type value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:mime_type ;
            sh:pattern "^(application|audio|font|image|message|model|multipart|text|video)/[a-zA-Z0-9.+_-]+" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether or not the data contained within the object has been defanged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:defanged ] ;
    sh:targetClass stix:Artifact .

stix:AttackPattern a sh:NodeShape ;
    rdfs:comment "Attack Patterns are a type of TTP that describe ways that adversaries attempt to compromise targets. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Alternative names for the object." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:aliases ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path stix:external_references ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:description ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^attack-pattern--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^attack-pattern$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:class stix:KillChainPhase ;
            sh:description "Kill chain phases associated with this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
