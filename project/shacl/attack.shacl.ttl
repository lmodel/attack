            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:description ] ;
    sh:targetClass stix:AlternateDataStreamType .

stix:CyberObservableObject a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( stix:command_line stix:body stix:contains_refs stix:belongs_to_refs stix:protocols stix:is_disabled stix:to_refs stix:hashes stix:validity_not_before stix:account_first_login stix:credential rdf:type stix:account_expires stix:content_type stix:parent_directory_ref stix:is_self_signed stix:path_enc stix:dst_payload_ref stix:rir stix:credential_last_changed stix:signature_algorithm stix:number stix:src_ref stix:content_ref stix:dst_byte_count stix:cc_refs stix:bcc_refs stix:is_active stix:encapsulated_by_ref stix:parent_ref stix:swid stix:dst_port stix:can_escalate_privs stix:version stix:payload_bin stix:path stix:additional_header_fields stix:issuer stix:decryption_key stix:end stix:belongs_to_ref stix:src_byte_count stix:display_name stix:ctime stix:mime_type stix:src_port stix:src_payload_ref stix:magic_number_hex stix:encryption_algorithm stix:user_id stix:values stix:dst_ref stix:subject stix:account_type stix:is_service_account stix:subject_public_key_exponent stix:validity_not_after stix:is_multipart stix:is_hidden stix:is_privileged stix:subject_public_key_modulus stix:opened_connection_refs stix:src_packets stix:creator_user_ref stix:from_ref stix:number_of_subkeys stix:child_refs stix:languages stix:account_created stix:sender_ref stix:subject_public_key_algorithm stix:modified_time stix:mtime stix:cpe stix:raw_email_ref stix:resolves_to_refs stix:atime stix:url stix:account_last_login stix:serial_number stix:cwd stix:received_lines stix:created_time stix:environment_variables stix:pid stix:size stix:start stix:ipfix stix:name_enc stix:message_id stix:x509_v3_extensions stix:value stix:account_login stix:vendor stix:body_multipart stix:dst_packets stix:encapsulates_refs stix:image_ref stix:email_date stix:key ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:type ;
