            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Malware analysis engine version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:analysis_engine_version ],
        [ sh:datatype xsd:string ;
