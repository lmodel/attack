        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^incident--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:name ] ;
    sh:targetClass stix:Incident .

stix:Indicator a sh:NodeShape ;
    rdfs:comment "Indicators contain a pattern that can be used to detect suspicious or malicious cyber activity. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:confidence ],
        [ sh:class stix:KillChainPhase ;
            sh:description "Kill chain phases associated with this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path stix:kill_chain_phases ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:extensions ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The time at which this indicator should no longer be considered valuable intelligence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:valid_until ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the pattern that is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:pattern_version ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The time from which this indicator should be considered valuable intelligence." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:valid_from ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:description "The type of pattern used in this indicator." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "stix" "pcre" "sigma" "snort" "suricata" "yara" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 2 ;
            sh:path stix:pattern_type ],
        [ sh:datatype xsd:string ;
            sh:description "The detection pattern for this indicator." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:pattern ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^indicator--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:revoked ],
        [ sh:description "This field is an Open Vocabulary that specifies the type of indicator. Open vocab - indicator-type-ov" ;
            sh:or ( [ sh:in ( "anomalous-activity" "anonymization" "benign" "compromised" "malicious-activity" "attribution" "unknown" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path stix:indicator_types ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^indicator$" ] ;
    sh:targetClass stix:Indicator .

