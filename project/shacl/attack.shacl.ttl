stix:X509V3ExtensionsType a sh:NodeShape ;
    rdfs:comment "Specifies any standard X.509 v3 extensions that may be used in the certificate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the identifier that provides a means of identifying the public key corresponding to the private key used to sign a certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:authority_key_identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies how CRL information is obtained." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:crl_distribution_points ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a list of usages indicating purposes for which the certificate public key can be used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:extended_key_usage ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the number of additional certificates that may appear in the path before anyPolicy is no longer permitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:inhibit_any_policy ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies one or more pairs of OIDs; each pair includes an issuerDomainPolicy and a subjectDomainPolicy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:policy_mappings ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a namespace within which all subject names in subsequent certificates in a certification path must be located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:name_constraints ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Specifies the date on which the validity period begins for the private key, if it is different from the validity period of the certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:private_key_usage_period_not_before ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Specifies the date on which the validity period ends for the private key, if it is different from the validity period of the certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:private_key_usage_period_not_after ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the additional identities to be bound to the issuer of the certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:issuer_alternative_name ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a multi-valued extension which indicates whether a certificate is a CA certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:basic_constraints ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the additional identities to be bound to the subject of the certificate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:subject_alternative_name ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies any constraints on path validation for certificates issued to CAs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:policy_constraints ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a sequence of one or more policy information terms, each of which consists of an object identifier (OID) and optional qualifiers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:certificate_policies ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a multi-valued extension consisting of a list of names of the permitted key usages." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:key_usage ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the identification attributes (e.g., nationality) of the subject." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:subject_directory_attributes ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the identifier that provides a means of identifying certificates that contain a particular public key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:subject_key_identifier ] ;
    sh:targetClass stix:X509V3ExtensionsType .

