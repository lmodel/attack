stix:ExternalReference a sh:NodeShape ;
    rdfs:comment "External references are used to describe pointers to information represented outside of STIX. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
