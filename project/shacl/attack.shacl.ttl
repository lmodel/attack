                "^software--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:extensions ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the Common Platform Enumeration (CPE) entry for the software." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:cpe ],
        [ sh:datatype xsd:string ;
            sh:description "Vendor name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:vendor ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the languages supported by the software." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:languages ],
        [ sh:datatype xsd:string ;
            sh:description "SWID tag value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:swid ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether or not the data contained within the object has been defanged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:defanged ],
        [ sh:datatype xsd:string ;
            sh:description "Version string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:version ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:description ] ;
    sh:targetClass stix:Software .

stix:StixDomainObject a sh:NodeShape ;
    sh:closed false ;
    sh:ignoredProperties ( stix:is_family stix:capabilities stix:latitude stix:last_seen stix:modules stix:roles stix:analysis_engine_version stix:sophistication stix:infrastructure_types rdf:type stix:operating_system_refs stix:submitted stix:aliases stix:pattern_type stix:postal_code stix:personal_motivations stix:region stix:street_address stix:implementation_languages stix:analysis_started stix:administrative_area stix:abstract stix:object_refs stix:authors stix:product stix:identity_class stix:result stix:contact_information stix:installed_software_refs stix:version stix:longitude stix:objects stix:primary_motivation stix:number_observed stix:tool_version stix:published stix:tool_types stix:sectors stix:valid_until stix:malware_types stix:valid_from stix:operating_system_ref stix:content stix:architecture_execution_envs stix:resource_level stix:result_name stix:indicator_types stix:objective stix:report_types stix:kill_chain_phases stix:city stix:opinion stix:first_seen stix:sample_refs stix:pattern_version stix:context stix:first_observed stix:country stix:host_vm_ref stix:analysis_sco_refs stix:secondary_motivations stix:threat_actor_types stix:pattern stix:goals stix:sample_ref stix:analysis_definition_version stix:precision stix:explanation stix:analysis_ended stix:last_observed stix:configuration_version ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:lang ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path stix:external_references ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ] ;
    sh:targetClass stix:StixDomainObject .

