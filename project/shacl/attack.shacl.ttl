                "^software--" ],
        [ sh:datatype xsd:string ;
            sh:description "Version string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:version ],
        [ sh:datatype xsd:string ;
            sh:description "Analysis result name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:result_name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^malware-analysis--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Malware sample submission timestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:submitted ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Analysis end timestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:analysis_ended ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Analysis start timestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:analysis_started ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced SCOs captured in analysis." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:analysis_sco_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Host VM software reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:host_vm_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^software--" ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 17 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:confidence ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Analysis subject sample reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:sample_ref ;
            sh:pattern "^(artifact--|file--|network-traffic--)",
                "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^malware-analysis$" ],
        [ sh:datatype xsd:string ;
            sh:description "Malware analysis product configuration version." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:configuration_version ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "Installed software references." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:installed_software_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^software--" ],
        [ sh:datatype xsd:string ;
            sh:description "Malware analysis product name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:product ] ;
    sh:targetClass stix:MalwareAnalysis .

stix:MarkingDefinition a sh:NodeShape ;
    rdfs:comment "The marking-definition object represents a specific marking. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Marking definition payload." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:definition ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "A statement (e.g., copyright, terms of use) applied to the content marked by this marking definition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:statement ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path stix:external_references ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^marking-definition$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:created ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^marking-definition--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Type discriminator for marking definition content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:definition_type ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^marking-definition--" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:description ] ;
    sh:targetClass stix:MarkingDefinition .

stix:Mutex a sh:NodeShape ;
    rdfs:comment "The Mutex Object represents the properties of a mutual exclusion (mutex) object. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^mutex$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^mutex--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether or not the data contained within the object has been defanged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:defanged ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:name ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ;
    sh:targetClass stix:Mutex .

stix:NetworkTraffic a sh:NodeShape ;
    rdfs:comment "The Network Traffic Object represents arbitrary network traffic that originates from a source and is addressed to a destination. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Source observable reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:src_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies any IP Flow Information Export (IPFIX) data for the traffic." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:ipfix ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:order 18 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:integer ;
            sh:description "Destination-to-source packet count." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:dst_packets ],
        [ sh:datatype xsd:integer ;
            sh:description "Source port number." ;
            sh:maxCount 1 ;
            sh:maxInclusive 65535 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:src_port ],
        [ sh:datatype xsd:string ;
            sh:description "Destination observable reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:dst_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Source payload reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:src_payload_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Source-to-destination packet count." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:src_packets ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Network traffic start time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:start ],
        [ sh:datatype xsd:integer ;
            sh:description "Bytes sent source to destination." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:src_byte_count ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether or not the data contained within the object has been defanged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:defanged ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:integer ;
            sh:description "Bytes sent destination to source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:dst_byte_count ],
        [ sh:datatype xsd:string ;
            sh:description "Destination payload reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:dst_payload_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced encapsulated network-traffic objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:encapsulates_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^network-traffic$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^network-traffic--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Network protocols list." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:protocols ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Network traffic end time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:end ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Referencing encapsulating network-traffic object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:encapsulated_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates traffic is still active." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:is_active ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path stix:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Destination port number." ;
            sh:maxCount 1 ;
            sh:maxInclusive 65535 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:dst_port ] ;
    sh:targetClass stix:NetworkTraffic .

stix:Note a sh:NodeShape ;
    rdfs:comment "A Note is a comment or note containing informative text to help explain the context of one or more STIX Objects (SDOs or SROs) or to provide additional analysis that is not contained in the original object. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Brief summary text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:abstract ],
        [ sh:datatype xsd:string ;
            sh:description "Author list." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:authors ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Main text content payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:content ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:confidence ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced STIX objects." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:object_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^note--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^note$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ] ;
    sh:targetClass stix:Note .

stix:NtfsExt a sh:NodeShape ;
    rdfs:comment "The NTFS extension specifies a default extension for capturing properties specific to the storage of the file on the NTFS file system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:AlternateDataStreamType ;
            sh:description "Specifies a list of NTFS alternate data streams that exist for the file." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path stix:alternate_data_streams ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the security ID (SID) value assigned to the file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:sid ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ] ;
    sh:targetClass stix:NtfsExt .

stix:ObservedData a sh:NodeShape ;
    rdfs:comment "Observed data conveys information that was observed on systems and networks, such as log data or network traffic, using the Cyber Observable specification. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of observations." ;
            sh:maxCount 1 ;
            sh:maxInclusive 999999999 ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:number_observed ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^observed-data--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path stix:external_references ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "End of observation window." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:last_observed ],
        [ sh:class stix:CyberObservableObject ;
            sh:description "Embedded cyber observable dictionary payload." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path stix:objects ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^observed-data$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Start of observation window." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:first_observed ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced STIX objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:object_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:description ] ;
    sh:targetClass stix:ObservedData .

stix:Opinion a sh:NodeShape ;
    rdfs:comment "An Opinion is an assessment of the correctness of the information in a STIX Object produced by a different entity and captures the level of agreement or disagreement using a fixed scale. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Referenced STIX objects." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:object_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^opinion--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path stix:external_references ],
        [ sh:description "Opinion value." ;
            sh:in ( "strongly-disagree" "disagree" "neutral" "agree" "strongly-agree" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path stix:opinion ],
        [ sh:datatype xsd:string ;
            sh:description "Author list." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:authors ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^opinion$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Explanation text for an opinion." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:explanation ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path stix:spec_version ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path stix:granular_markings ] ;
    sh:targetClass stix:Opinion .

stix:PEBinaryExt a sh:NodeShape ;
    rdfs:comment "The Windows PE Binary File extension specifies a default extension for capturing properties specific to Windows portable executable (PE) files." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the size of the optional header of the PE binary." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:size_of_optional_header ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the flags that indicate the file's characteristics." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:characteristics_hex ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:description ],
        [ sh:class stix:WindowsPESection ;
            sh:description "Specifies metadata about the sections in the PE file." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path stix:sections ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the file offset of the COFF symbol table." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:pointer_to_symbol_table_hex ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Specifies the time when the PE binary was created. The timestamp value MUST BE precise to the second." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:time_date_stamp ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the type of target machine." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:machine_hex ],
        [ sh:description "Specifies the type of the PE binary. Open Vocabulary - windows-pebinary-type-ov" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "exe" "dll" "sys" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path stix:pe_type ],
        [ sh:class stix:WindowsPEOptionalHeaderType ;
            sh:description "Specifies the PE optional header of the PE binary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path stix:optional_header ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the number of entries in the symbol table of the PE binary, as a non-negative integer." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:number_of_symbols ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the number of sections in the PE binary, as a non-negative integer." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:number_of_sections ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the special import hash, or 'imphash', calculated for the PE binary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:imphash ],
        [ sh:class stix:HashesType ;
            sh:description "Specifies any hashes that were computed for the file header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path stix:file_header_hashes ] ;
    sh:targetClass stix:PEBinaryExt .

stix:PdfExt a sh:NodeShape ;
    rdfs:comment "The PDF extension specifies a default extension for capturing properties specific to PDF files." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the second file identifier found for the PDF file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:pdfid1 ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies details of the PDF document information dictionary (DID), which includes properties like the document creation date and producer, as a dictionary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:document_info_dict ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Version string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:version ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the first file identifier found for the PDF file." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:pdfid0 ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the PDF file has been optimized." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:is_optimized ] ;
    sh:targetClass stix:PdfExt .

stix:Process a sh:NodeShape ;
    rdfs:comment "The Process Object represents common properties of an instance of a computer program as executed on an operating system. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Process creation time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:created_time ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced opened network connections." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:opened_connection_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Process image file reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:image_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the process is hidden." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:is_hidden ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the Process ID, or PID, of the process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:pid ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^process--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Current working directory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:cwd ],
        [ sh:datatype xsd:string ;
            sh:description "Environment variable payload." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:environment_variables ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:extensions ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^process$" ],
        [ sh:datatype xsd:string ;
            sh:description "Process command line." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:command_line ],
        [ sh:datatype xsd:string ;
            sh:description "Creating user reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:creator_user_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Parent process reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:parent_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Child process references." ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:child_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether or not the data contained within the object has been defanged." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:defanged ] ;
    sh:targetClass stix:Process .

stix:Properties a sh:NodeShape ;
    rdfs:comment "Rules for custom properties " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ;
    sh:targetClass stix:Properties .

stix:RasterImageExt a sh:NodeShape ;
    rdfs:comment "The Raster Image extension specifies a default extension for capturing properties specific to raster image files." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the width of the image in the image file, in pixels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:image_width ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the set of EXIF tags found in the image file, as a dictionary. Each key/value pair in the dictionary represents the name/value of a single EXIF tag." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:exif_tags ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:name ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the sum of bits used for each color channel in the image in the image file, and thus the total number of pixels used for expressing the color depth of the image." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:bits_per_pixel ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the height of the image in the image file, in pixels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:image_height ] ;
    sh:targetClass stix:RasterImageExt .

stix:Relationship a sh:NodeShape ;
    rdfs:comment "The Relationship object is used to link together two SDOs in order to describe how they are related to each other. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Relationship target object reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:target_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path stix:external_references ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Start timestamp for temporal relationship validity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:start_time ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Name of the relationship type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:relationship_type ;
            sh:pattern "^[a-z0-9\\-]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^relationship$" ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:string ;
            sh:description "Relationship source object reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:source_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^relationship--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "End timestamp for temporal relationship validity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:stop_time ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path stix:name ] ;
    sh:targetClass stix:Relationship .

stix:Report a sh:NodeShape ;
    rdfs:comment "Reports are collections of threat intelligence focused on one or more topics, such as a description of a threat actor, malware, or attack technique, including context and related details. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path stix:spec_version ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:labels ],
        [ sh:description "Open-vocabulary report categories." ;
            sh:or ( [ sh:in ( "attack-pattern" "campaign" "identity" "indicator" "intrusion-set" "malware" "observed-data" "threat-actor" "threat-report" "tool" "vulnerability" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path stix:report_types ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced STIX objects." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:object_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^report$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when a report was published." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:published ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^report--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:confidence ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path stix:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ;
    sh:targetClass stix:Report .

stix:Sighting a sh:NodeShape ;
    rdfs:comment "A Sighting denotes the belief that something in CTI (e.g., an indicator, malware, tool, threat actor, etc.) was seen. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Reference to the object being sighted." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path stix:sighting_of_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether this object has been revoked." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path stix:revoked ],
        [ sh:datatype xsd:dateTime ;
            sh:description "First time observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:first_seen ],
        [ sh:datatype xsd:string ;
            sh:description "References to identities or locations where sighted." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:where_sighted_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:description "STIX specification version." ;
            sh:in ( "2.0" "2.1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path stix:spec_version ],
        [ sh:class stix:GranularMarking ;
            sh:description "Granular markings that apply to selected content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path stix:granular_markings ],
        [ sh:datatype xsd:integer ;
            sh:description "This is an integer between 0 and 999,999,999 inclusive and represents the number of times the object was sighted." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:count ],
        [ sh:datatype xsd:string ;
            sh:description "Marking definition references applied to this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path stix:object_marking_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path stix:description ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "^sighting--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Language of textual properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path stix:lang ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last time observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path stix:last_seen ],
        [ sh:datatype xsd:boolean ;
            sh:description "The summary property indicates whether the Sighting should be considered summary data." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:summary ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path stix:name ],
        [ sh:datatype xsd:string ;
            sh:description "Terms used to describe this object." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path stix:labels ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence that the producer has in this data." ;
            sh:maxCount 1 ;
            sh:maxInclusive 100 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path stix:confidence ],
        [ sh:datatype xsd:string ;
            sh:description "Open-ended extension payloads." ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path stix:extensions ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$",
                "^sighting$" ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the object that created this object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path stix:created_by_ref ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Modification timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path stix:modified ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:created ;
            sh:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ],
        [ sh:class stix:ExternalReference ;
            sh:description "External references to non-STIX information." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path stix:external_references ],
        [ sh:datatype xsd:string ;
            sh:description "References to observed-data objects." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:observed_data_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ;
    sh:targetClass stix:Sighting .

stix:SocketExt a sh:NodeShape ;
    rdfs:comment "The Socket extension specifies a default extension for capturing network traffic properties specific to network sockets. Used as the value of the 'socket-ext' key in a NetworkTraffic object's extensions dictionary." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path stix:id ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path stix:name ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the socket is in blocking mode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:is_blocking ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies any options (SO_*) that may be used by the socket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path stix:socket_options ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the handle or inode value associated with the socket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path stix:socket_handle ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the socket is in listening mode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path stix:is_listening ],
        [ sh:description "Specifies the type of the socket." ;
            sh:in ( "SOCK_STREAM" "SOCK_DGRAM" "SOCK_RAW" "SOCK_RDM" "SOCK_SEQPACKET" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path stix:socket_type ],
        [ sh:description "Specifies the address family (AF_*) that the socket is configured for." ;
            sh:in ( "AF_UNSPEC" "AF_INET" "AF_IPX" "AF_APPLETALK" "AF_NETBIOS" "AF_INET6" "AF_IRDA" "AF_BTH" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path stix:address_family ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the socket file descriptor value associated with the socket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path stix:socket_descriptor ],
        [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path stix:type ;
            sh:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path stix:description ] ;
    sh:targetClass stix:SocketExt .

stix:Software a sh:NodeShape ;
    rdfs:comment "The Software Object represents high-level properties associated with software, including software products. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "STIX object type." ;
