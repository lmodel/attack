stix:Ipv4Addr a sh:NodeShape ;
    rdfs:comment "The IPv4 Address Object represents one or more IPv4 addresses expressed using CIDR notation. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "References this observable resolves to." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path stix:resolves_to_refs ;
            sh:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ],
        [ sh:class stix:GranularMarking ;
