    {
      "name": "x_mitre_old_attack_id",
      "definition_uri": "https://w3id.org/lmodel/attack/x_mitre_old_attack_id",
      "description": "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset).",
      "in_subset": [
