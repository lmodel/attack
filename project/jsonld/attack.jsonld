      "@type": "ClassDefinition"
    },
    {
      "name": "Group",
      "definition_uri": "https://w3id.org/lmodel/attack/Group",
      "annotations": [
        {
          "tag": "stix_type",
          "value": "intrusion-set",
          "@type": "Annotation"
        },
        {
          "tag": "attack_id_format",
          "value": "G####",
          "@type": "Annotation"
        }
      ],
      "description": "Groups represent clusters of adversary activity attributed to a common actor, sharing characteristics such as tools, tactics, techniques, infrastructure, or targeting. They may represent nation-state actors, criminal organizations, hacktivist collectives, or other tracked threat entities.\nGroups are implemented as standard STIX intrusion-set objects without additional ATT&CK-specific custom properties beyond the shared ATT&CK base fields. The aliases array provides alternative names; the first alias MUST match the group's name property.\nNote: Several STIX Intrusion Set properties (goals, resource_level, primary_motivation, secondary_motivations, first_seen, last_seen) are inherited from STIX but are not actively used or populated in ATT&CK Group objects.",
      "comments": [
        "validator_hint: first-aliases-entry-must-match-name"
      ],
      "in_subset": [
        "attack_sdos"
      ],
      "from_schema": "https://w3id.org/lmodel/attack",
      "is_a": "AttackObject",
      "slots": [
        "Core_labels",
        "revoked",
        "confidence",
        "lang",
        "Core_object_marking_refs",
        "Core_granular_markings",
        "extensions",
        "AttackObject_x_mitre_attack_spec_version",
        "AttackObject_x_mitre_version",
        "x_mitre_deprecated",
        "x_mitre_old_attack_id",
        "AttackObject_spec_version",
        "AttackObject_created",
        "AttackObject_modified",
        "AttackObject_created_by_ref",
        "Group_x_mitre_domains",
        "x_mitre_contributors",
