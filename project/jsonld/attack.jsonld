      "owner": "RelatedAsset",
      "domain_of": [
        "RelatedAsset"
      ],
      "range": "AttackAssetSectorEnum",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "log_source_name",
      "definition_uri": "https://w3id.org/lmodel/attack/log_source_name",
      "description": "The log source provider or service name (e.g., 'sysmon', 'auditd', 'unified_logs', 'windows_security'). Together with log_source_channel, uniquely identifies a specific log collection configuration.",
      "in_subset": [
        "attack_aux"
      ],
      "from_schema": "https://w3id.org/lmodel/attack",
      "slot_uri": "https://w3id.org/lmodel/attack/log_source_name",
      "owner": "LogSourceReference",
      "domain_of": [
        "LogSource",
        "LogSourceReference"
      ],
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "log_source_channel",
      "definition_uri": "https://w3id.org/lmodel/attack/log_source_channel",
      "description": "The specific log channel, event ID, or event category within the log source (e.g., '1' for Sysmon Process Creation event, 'SYSCALL' for Linux auditd, 'process' for macOS unified logs). Together with log_source_name, uniquely identifies a log collection configuration.",
      "in_subset": [
        "attack_aux"
      ],
      "from_schema": "https://w3id.org/lmodel/attack",
      "slot_uri": "https://w3id.org/lmodel/attack/log_source_channel",
      "owner": "LogSourceReference",
      "domain_of": [
        "LogSource",
        "LogSourceReference"
      ],
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "x_mitre_data_component_ref",
      "definition_uri": "https://w3id.org/lmodel/attack/x_mitre_data_component_ref",
      "description": "The STIX ID of the x-mitre-data-component object that this log source reference is associated with. Links the analytic's required data collection to a specific data component's log source definition.",
