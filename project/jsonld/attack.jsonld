      "@type": "SlotDefinition"
    },
    {
      "name": "mutable_field",
      "definition_uri": "https://w3id.org/lmodel/attack/mutable_field",
      "description": "The name of the analytic field or parameter that can be tuned by a defender to adapt it to their environment (e.g., 'TimeWindow', 'UserContext', 'PortRange', 'SubnetFilter'). Provides a clear identifier for the tunable aspect of the analytic.",
