    },
    {
      "name": "AttackTool",
      "definition_uri": "https://w3id.org/lmodel/attack/AttackTool",
      "annotations": [
        {
          "tag": "stix_type",
          "value": "tool",
          "@type": "Annotation"
        },
        {
          "tag": "attack_id_format",
          "value": "S####",
          "@type": "Annotation"
        }
      ],
      "description": "Tools represent legitimate software programs that adversaries may abuse or repurpose to accomplish their attack objectives. Unlike Malware, tools are not inherently malicious \u2014 they serve legitimate purposes but can be weaponized by adversaries (e.g., Cobalt Strike, Mimikatz, PsExec, Metasploit).\nTogether with Malware objects, Tools form the ATT&CK 'Software' category and share the same ATT&CK ID format (S####). Both are linked to Groups and Techniques via 'uses' relationships.\nThe x_mitre_aliases field holds ATT&CK-recognized alternative names; the first alias MUST match the object's name. The STIX 'aliases' property is not actively maintained in ATT&CK Tool objects.\nNote: STIX Tool properties (tool_types, kill_chain_phases, tool_version, aliases) are available from the STIX specification but not actively used in ATT&CK Tool objects.",
      "notes": [
        "The class name 'attack:Software' collides with (is_a) 'stix:Software', so renamed.",
        "The class name 'attack:Tool' collides with 'stix:Tool', so renamed."
      ],
      "comments": [
        "validator_hint: first-x-mitre-alias-or-alias-must-match-name"
      ],
      "in_subset": [
        "attack_sdos"
      ],
      "from_schema": "https://w3id.org/lmodel/attack",
      "is_a": "AttackSoftware",
      "slots": [
