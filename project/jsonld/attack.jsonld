    },
    {
      "name": "x_mitre_platforms",
      "definition_uri": "https://w3id.org/lmodel/attack/x_mitre_platforms",
      "description": "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted.",
      "comments": [
        "jsonschema_minItems: \"1\" validator_hint: no-duplicate-platforms"
