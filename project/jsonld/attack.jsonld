    {
      "name": "DetectionStrategy",
      "definition_uri": "https://w3id.org/lmodel/attack/DetectionStrategy",
      "annotations": [
        {
          "tag": "stix_type",
          "value": "x-mitre-detection-strategy",
          "@type": "Annotation"
        },
        {
          "tag": "attack_id_format",
          "value": "DET####",
          "@type": "Annotation"
        }
      ],
      "description": "Detection Strategies define high-level, platform-agnostic approaches for detecting specific adversary techniques. They function as containers organizing one or more platform-specific Analytics (x-mitre-analytic objects) into cohesive detection methodologies, describing what data to collect and what behavioral patterns to look for.\nDetection Strategies were introduced in ATT&CK Specification 3.3.0 as part of the new detection framework, superseding the deprecated x-mitre-data-source and x-mitre-data-component approach for technique detection.\nA Detection Strategy links to its implementing analytics via x_mitre_analytic_refs. Analytics in turn link back to data components via x_mitre_log_source_references, creating a complete detection chain from technique to observable log event.",
      "in_subset": [
        "attack_sdos"
      ],
      "from_schema": "https://w3id.org/lmodel/attack",
      "is_a": "AttackObject",
      "slots": [
        "description",
        "Core_labels",
        "revoked",
        "confidence",
        "lang",
        "Core_granular_markings",
        "extensions",
        "AttackObject_x_mitre_attack_spec_version",
        "AttackObject_x_mitre_version",
        "x_mitre_deprecated",
        "x_mitre_old_attack_id",
        "AttackObject_spec_version",
        "AttackObject_created",
        "AttackObject_modified",
        "DetectionStrategy_x_mitre_domains",
        "DetectionStrategy_x_mitre_modified_by_ref",
        "DetectionStrategy_x_mitre_contributors",
        "DetectionStrategy_x_mitre_analytic_refs",
        "DetectionStrategy_type",
        "DetectionStrategy_id",
        "DetectionStrategy_name",
        "DetectionStrategy_external_references",
        "DetectionStrategy_created_by_ref",
        "DetectionStrategy_object_marking_refs"
      ],
      "slot_usage": {},
