    {
      "name": "x_mitre_modified_by_ref",
      "definition_uri": "https://w3id.org/lmodel/attack/x_mitre_modified_by_ref",
      "description": "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE.",
      "comments": [
        "validator_hint: must-match-mitre-identity-id"
      ],
      "in_subset": [
        "attack_sdos",
        "attack_sros"
      ],
      "from_schema": "https://w3id.org/lmodel/attack",
