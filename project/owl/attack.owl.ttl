            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-matrix$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        attack:AttackObject ;
    skos:definition """ATT&CK Matrices define the structural layout and organization of tactics and techniques within each ATT&CK domain. The matrix arranges tactics as columns and techniques (with sub-techniques nested beneath parents) as rows, providing a comprehensive visual map of adversary behavior within a domain.
Each ATT&CK domain has exactly one Matrix object. The tactic_refs property contains an ordered list of x-mitre-tactic STIX IDs that defines the left-to-right display order of columns in the ATT&CK matrix. The matrix does not directly enumerate techniques — technique-to-tactic associations are captured via kill_chain_phases on the Technique objects.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:stix_type "x-mitre-matrix" .

attack:Mitigation a owl:Class ;
    rdfs:label "Mitigation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^course-of-action--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^course-of-action$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDomainEnum ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        attack:AttackObject ;
    skos:definition """Mitigations describe defensive measures, security controls, and configuration changes that can prevent or reduce the effectiveness of adversary techniques. Mitigations are implemented as STIX course-of-action objects.
Historical note — Legacy 1:1 Mitigations: Prior to ATT&CK v5 (July 2019), mitigations had a 1:1 relationship with techniques and shared their ATT&CK IDs. This design was deprecated to support the current many-to-many model where one mitigation can address multiple techniques. Legacy 1:1 mitigation objects may cause ATT&CK ID collisions and can be filtered by their deprecated or revoked status.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:attack_id_format "M####" ;
    attack:stix_type "course-of-action" .

attack:StatementMarkingObject a owl:Class ;
    rdfs:label "StatementMarkingObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:statement ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:statement ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:statement ] ;
    skos:definition "The definition payload for a statement marking definition. Contains a single statement field with a copyright notice or terms-of-use text. ATT&CK uses this for its standard copyright statement applied to all distributed content." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:Tactic a owl:Class ;
    rdfs:label "Tactic" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_shortname ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackTacticShortNameEnum ;
            owl:onProperty attack:x_mitre_shortname ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDomainEnum ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_shortname ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-tactic--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-tactic$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        attack:AttackObject ;
    skos:definition """Tactics represent the adversary's high-level strategic objectives during an attack — the "why" behind individual techniques. Tactics form the columns of the ATT&CK matrix and organize techniques into coherent operational categories.
Tactics are implemented as x-mitre-tactic custom STIX objects that extend the STIX Domain Object pattern. They are specific to ATT&CK and not defined by the core STIX 2.1 specification.
The x_mitre_shortname property is the machine-readable tactic identifier used to link techniques: a technique's kill_chain_phases entry uses x_mitre_shortname as phase_name when kill_chain_name matches the appropriate ATT&CK domain value.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:attack_id_format "TA####" ;
    attack:stix_type "x-mitre-tactic" .

attack:Technique a owl:Class ;
    rdfs:label "Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackImpactTypeEnum ;
            owl:onProperty attack:x_mitre_impact_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty attack:x_mitre_remote_support ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_detection ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackPermissionsRequiredEnum ;
            owl:onProperty attack:x_mitre_permissions_required ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_is_subtechnique ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_remote_support ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:kill_chain_phases ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^attack-pattern$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_tactic_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_system_requirements ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_system_requirements ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_detection ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_platforms ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty attack:x_mitre_is_subtechnique ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_network_requirements ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_impact_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_network_requirements ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty attack:x_mitre_network_requirements ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_data_sources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_permissions_required ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_defense_bypassed ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDomainEnum ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^attack-pattern--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackTacticTypeEnum ;
            owl:onProperty attack:x_mitre_tactic_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_is_subtechnique ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_remote_support ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_detection ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackEffectivePermissionsEnum ;
            owl:onProperty attack:x_mitre_effective_permissions ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDefenseBypassEnum ;
            owl:onProperty attack:x_mitre_defense_bypassed ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_data_sources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_effective_permissions ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackKillChainPhase ;
            owl:onProperty attack:kill_chain_phases ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackPlatformEnum ;
            owl:onProperty attack:x_mitre_platforms ],
        attack:AttackObject ;
    skos:definition """Techniques describe the specific methods adversaries use to achieve tactical objectives. They are implemented as STIX attack-pattern objects and represent the "how" of adversary behavior — the concrete actions taken to accomplish a tactic.
A Technique may be a top-level technique (x_mitre_is_subtechnique: false) or a sub-technique (x_mitre_is_subtechnique: true). Sub-techniques provide more granular detail about specific implementations of their parent technique.
Sub-technique constraints:
  - ATT&CK ID format: T####.### where T#### is the parent's ID
  - Connected to parent via 'subtechnique-of' relationship (source = sub, target = parent)
  - Each sub-technique has exactly one parent; parents may have many sub-techniques
  - Sub-techniques inherit all parent tactics; platforms must be a subset of parent's

Tactics mapping: kill_chain_phases entries use the tactic's x_mitre_shortname as phase_name, with kill_chain_name set to the appropriate ATT&CK domain value.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:attack_id_format "T#### (technique) or T####.### (sub-technique)" ;
    attack:stix_type "attack-pattern" .

attack:TlpMarkingObject a owl:Class ;
    rdfs:label "TlpMarkingObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:tlp ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:TlpLevelEnum ;
            owl:onProperty attack:tlp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:tlp ] ;
    skos:definition "The definition payload for a TLP (Traffic Light Protocol) marking definition. Contains a single tlp field carrying the TLP level value. Only instances corresponding to the four canonical ATT&CK TLP marking definitions are valid; new TLP marking objects must not be created." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

stix:ArchiveExt a owl:Class ;
    rdfs:label "ArchiveExt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:comment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:contains_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:comment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:comment ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:contains_refs ],
        stix:CommonSchemaComponent ;
    skos:definition "The Archive File extension specifies a default extension for capturing properties specific to archive files, such as ZIP." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "stix_extension_key: archive-ext stix_parent_type: file jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/file.json" .

stix:Artifact a owl:Class ;
    rdfs:label "Artifact" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:encryption_algorithm ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty stix:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:decryption_key ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^artifact$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:payload_bin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:decryption_key ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:mime_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^(application|audio|font|image|message|model|multipart|text|video)/[a-zA-Z0-9.+_-]+" ] ) ] ) ] ;
            owl:onProperty stix:mime_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:payload_bin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:encryption_algorithm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:mime_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^artifact--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:payload_bin ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:decryption_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:HashesType ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:encryption_algorithm ],
        stix:CyberObservableObject ;
    skos:definition "The Artifact Object permits capturing an array of bytes (8-bits), as a base64-encoded string string, or linking to a file-like payload. " ;
    skos:editorialNote "JSON Schema enforces oneOf for payload_bin vs url+hashes and conditional decryption rules." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: oneOf validator_hint: enforce-artifact-exclusive-payload-and-encryption-rules jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/artifact.json" .

stix:AttackPattern a owl:Class ;
    rdfs:label "AttackPattern" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:kill_chain_phases ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:KillChainPhase ;
            owl:onProperty stix:kill_chain_phases ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
