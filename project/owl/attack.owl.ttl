    skos:definition "Cc-recipient references." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:child_refs a owl:DatatypeProperty ;
    rdfs:label "child_refs" ;
    rdfs:range xsd:string ;
    skos:definition "Child process references." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:descriptions a owl:DatatypeProperty ;
    rdfs:label "descriptions" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the descriptions defined for the service." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:encapsulates_refs a owl:DatatypeProperty ;
    rdfs:label "encapsulates_refs" ;
    rdfs:range xsd:string ;
    skos:definition "Referenced encapsulated network-traffic objects." ;
