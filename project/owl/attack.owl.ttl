stix:time_date_stamp a owl:DatatypeProperty ;
    rdfs:label "time_date_stamp" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Specifies the time when the PE binary was created. The timestamp value MUST BE precise to the second." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:tool_version a owl:DatatypeProperty ;
    rdfs:label "tool_version" ;
    rdfs:range xsd:string ;
    skos:definition "Version identifier for a tool." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:user_id a owl:DatatypeProperty ;
    rdfs:label "user_id" ;
