            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:goals ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:primary_motivation ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^threat-actor--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:AttackResourceLevelOv xsd:string ) ] ;
            owl:onProperty stix:resource_level ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:aliases ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:threat_actor_types ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:personal_motivations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:first_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:aliases ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:AttackMotivationOv xsd:string ) ] ;
            owl:onProperty stix:secondary_motivations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:sophistication ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:AttackMotivationOv xsd:string ) ] ;
            owl:onProperty stix:personal_motivations ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:ThreatActorRoleOv xsd:string ) ] ;
            owl:onProperty stix:roles ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:goals ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:first_seen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:sophistication ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:resource_level ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:secondary_motivations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:last_seen ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:ThreatActorSophisticationOv xsd:string ) ] ;
            owl:onProperty stix:sophistication ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^threat-actor$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:AttackMotivationOv xsd:string ) ] ;
            owl:onProperty stix:primary_motivation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:resource_level ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:primary_motivation ],
        [ a owl:Restriction ;
