            owl:onProperty stix:extension_type ],
        stix:CommonSchemaComponent ;
    skos:definition "Converted from common/extension.json" ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_minProperties: \"1\" jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/extension.json" .

stix:ExtensionDefinition a owl:Class ;
    rdfs:label "ExtensionDefinition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:ExtensionTypeEnum ;
            owl:onProperty stix:extension_types ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:schema ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:extension_properties ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:schema ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:extension_properties ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^extension-definition--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ) ] ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:schema ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^extension-definition$" ] ) ] ) ] ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:extension_types ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:description ],
        stix:Core ;
    skos:definition "The STIX Extension Definition object allows producers of threat intelligence to extend existing STIX objects or to create entirely new STIX objects in a standardized way. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: if-then validator_hint: extension-definition-top-level-property-constraint jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/extension-definition.json" .

stix:File a owl:Class ;
    rdfs:label "File" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:content_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:ctime ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:atime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:atime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:mime_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:magic_number_hex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:magic_number_hex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:size ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:content_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:name_enc ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^[a-zA-Z0-9/\\.+_:-]{2,250}$" ] ) ] ) ] ;
            owl:onProperty stix:name_enc ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:mtime ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^file--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ) ] ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:mime_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:size ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:atime ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:extensions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:name_enc ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^file$" ] ) ] ) ] ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:mtime ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:extensions ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:HashesType ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:parent_directory_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:magic_number_hex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:mtime ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty stix:size ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:content_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:parent_directory_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:contains_refs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:parent_directory_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:ctime ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:ctime ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:mime_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:contains_refs ],
        stix:CyberObservableObject ;
    skos:definition "The File Object represents the properties of a file. " ;
    skos:editorialNote "JSON Schema requires at least one of hashes or name." ;
    skos:exactMatch unified_cyber_ontology:File ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: anyOf exactly_one_of_hint: \"hashes|name-at-least-one\" jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/file.json" .

stix:Grouping a owl:Class ;
    rdfs:label "Grouping" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:object_refs ],
        [ a owl:Restriction ;
