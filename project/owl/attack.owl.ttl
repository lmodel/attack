attack:ObjectVersionReference a owl:Class ;
    rdfs:label "ObjectVersionReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:object_modified ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:object_modified ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:object_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:object_modified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:object_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:object_ref ] ;
    skos:definition "A versioned reference to a specific state of a STIX object, consisting of the object's STIX identifier paired with the exact modified timestamp of the version being referenced. Used in the x_mitre_contents property of Collection objects to designate the precise snapshot of each included object. The object_modified value must exactly match the corresponding object's modified property." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

