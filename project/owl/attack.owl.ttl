        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:context ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:context ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^grouping$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^grouping--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:context ],
        stix:StixDomainObject ;
    skos:definition "A Grouping object explicitly asserts that the referenced STIX Objects have a shared content. " ;
    skos:exactMatch unified_cyber_ontology:Grouping ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sdos/grouping.json" .

stix:Hex a owl:Class ;
    rdfs:label "Hex" ;
    rdfs:subClassOf stix:CommonSchemaComponent ;
    skos:definition "The hex data type encodes an array of octets (8-bit bytes) as hexadecimal. The string MUST consist of an even number of hexadecimal characters, which are the digits '0' through '9' and the letters 'a' through 'f'. In order to allow pattern matching on custom objects, all properties that use the hex type, the property name MUST end with '_hex'. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_type: string jsonschema_pattern: \"^([a-fA-F0-9]{2})+$\" jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/hex.json" .

stix:HttpRequestExt a owl:Class ;
    rdfs:label "HttpRequestExt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:request_value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:request_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:request_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:message_body_length ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:request_method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:request_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:request_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty stix:message_body_length ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:request_header ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:message_body_data_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:message_body_data_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:request_header ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:request_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:request_header ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:message_body_data_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:message_body_length ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:request_method ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:request_version ],
        stix:CommonSchemaComponent ;
    skos:definition "The HTTP Request extension specifies a default extension for capturing network traffic properties specific to HTTP requests. Used as the value of the 'http-request-ext' key in a NetworkTraffic object's extensions dictionary." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "stix_extension_key: http-request-ext stix_parent_type: network-traffic jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/network-traffic.json" .

stix:IcmpExt a owl:Class ;
    rdfs:label "IcmpExt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:icmp_code_hex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:icmp_type_hex ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:icmp_type_hex ],
        [ a owl:Restriction ;
