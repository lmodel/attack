stix:extension_properties a owl:DatatypeProperty ;
    rdfs:label "extension_properties" ;
    rdfs:range xsd:string ;
    skos:definition "Extension-defined property names." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:extension_types a owl:ObjectProperty ;
    rdfs:label "extension_types" ;
    rdfs:range attack:ExtensionTypeEnum ;
    skos:definition "Extension-definition type list." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:groups a owl:DatatypeProperty ;
    rdfs:label "groups" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies a list of names of groups the account is a member of." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:implementation_languages a owl:DatatypeProperty ;
    rdfs:label "implementation_languages" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ImplementationLanguageOv xsd:string ) ] ;
    skos:definition "Open-vocabulary implementation languages (implementation-language-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ImplementationLanguageOv" .

stix:indicator_types a owl:DatatypeProperty ;
    rdfs:label "indicator_types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:IndicatorTypeOv xsd:string ) ] ;
    skos:definition "This field is an Open Vocabulary that specifies the type of indicator. Open vocab - indicator-type-ov" ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: IndicatorTypeOv" .

stix:infrastructure_types a owl:DatatypeProperty ;
    rdfs:label "infrastructure_types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:InfrastructureTypeOv xsd:string ) ] ;
    skos:definition "Open-vocabulary infrastructure categories (infrastructure-type-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: InfrastructureTypeOv" .

stix:installed_software_refs a owl:DatatypeProperty ;
    rdfs:label "installed_software_refs" ;
    rdfs:range xsd:string ;
    skos:definition "Installed software references." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:labels a owl:DatatypeProperty ;
    rdfs:label "labels" ;
    rdfs:range xsd:string ;
    skos:closeMatch unified_cyber_ontology:tag ;
    skos:definition "Terms used to describe this object." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:languages a owl:DatatypeProperty ;
    rdfs:label "languages" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the languages supported by the software." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:malware_types a owl:DatatypeProperty ;
    rdfs:label "malware_types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:MalwareTypeOv xsd:string ) ] ;
    skos:definition "Open-vocabulary malware types (malware-type-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: MalwareTypeOv" .

stix:modules a owl:DatatypeProperty ;
    rdfs:label "modules" ;
    rdfs:range xsd:string ;
    skos:definition "Malware analysis module names." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:objects a owl:ObjectProperty ;
    rdfs:label "objects" ;
    rdfs:range stix:CyberObservableObject ;
    skos:definition "Embedded cyber observable dictionary payload." ;
    skos:editorialNote "JSON Schema models this as a pattern-keyed dictionary of SCO objects." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: patternProperties+oneOf validator_hint: validate-observed-data-objects-dictionary" .

stix:observed_data_refs a owl:DatatypeProperty ;
    rdfs:label "observed_data_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References to observed-data objects." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:opened_connection_refs a owl:DatatypeProperty ;
    rdfs:label "opened_connection_refs" ;
    rdfs:range xsd:string ;
    skos:definition "Referenced opened network connections." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:operating_system_refs a owl:DatatypeProperty ;
    rdfs:label "operating_system_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References to software operating systems." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:personal_motivations a owl:DatatypeProperty ;
    rdfs:label "personal_motivations" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:AttackMotivationOv xsd:string ) ] ;
    skos:definition "Personal motivations of the threat actor (attack-motivation-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: AttackMotivationOv" .

stix:protocols a owl:DatatypeProperty ;
    rdfs:label "protocols" ;
    rdfs:range xsd:string ;
    skos:definition "Network protocols list." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:relatedMatch unified_cyber_ontology:hasFacet .

stix:received_lines a owl:DatatypeProperty ;
    rdfs:label "received_lines" ;
    rdfs:range xsd:string ;
    skos:definition "Received header lines." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:report_types a owl:DatatypeProperty ;
    rdfs:label "report_types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ReportTypeOv xsd:string ) ] ;
    skos:definition "Open-vocabulary report categories." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ReportTypeOv" ;
    skos:relatedMatch unified_cyber_ontology:tag .

stix:sample_refs a owl:DatatypeProperty ;
    rdfs:label "sample_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References to associated sample artifacts/files." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sections a owl:ObjectProperty ;
    rdfs:label "sections" ;
    rdfs:range stix:WindowsPESection ;
    skos:definition "Specifies metadata about the sections in the PE file." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sectors a owl:DatatypeProperty ;
    rdfs:label "sectors" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:IndustrySectorOv xsd:string ) ] ;
    skos:definition "Identity sector values (industry-sector-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: IndustrySectorOv" ;
    skos:relatedMatch unified_cyber_ontology:Location .

stix:selectors a owl:DatatypeProperty ;
    rdfs:label "selectors" ;
    rdfs:range xsd:string ;
    skos:definition "A list of selectors for content contained within the STIX object in which this property appears." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:service_dll_refs a owl:DatatypeProperty ;
    rdfs:label "service_dll_refs" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the DLLs loaded by the service." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:threat_actor_types a owl:DatatypeProperty ;
    rdfs:label "threat_actor_types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ThreatActorTypeOv xsd:string ) ] ;
    skos:definition "Open-vocabulary threat actor categories." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ThreatActorTypeOv" ;
    skos:relatedMatch unified_cyber_ontology:tag .

stix:to_refs a owl:DatatypeProperty ;
    rdfs:label "to_refs" ;
    rdfs:range xsd:string ;
    skos:definition "To-recipient references." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:tool_types a owl:DatatypeProperty ;
    rdfs:label "tool_types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ToolTypeOv xsd:string ) ] ;
    skos:definition "Open-vocabulary tool categories (tool-type-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ToolTypeOv" .

stix:values a owl:ObjectProperty ;
    rdfs:label "values" ;
    rdfs:range stix:WindowsRegistryValue ;
    skos:definition "Registry value entries." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:where_sighted_refs a owl:DatatypeProperty ;
    rdfs:label "where_sighted_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References to identities or locations where sighted." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

attack:AttackKillChainPhase a owl:Class ;
    rdfs:label "AttackKillChainPhase" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:phase_name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:kill_chain_name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:phase_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:phase_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:kill_chain_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:KillChainNameEnum ;
            owl:onProperty attack:kill_chain_name ],
        stix:KillChainPhase ;
    skos:definition "An ATT&CK-constrained kill chain phase restricting kill_chain_name to the three ATT&CK domain identifiers: 'mitre-attack', 'mitre-mobile-attack', and 'mitre-ics-attack'. The phase_name must match the x_mitre_shortname of the associated x-mitre-tactic object in the same domain. Used in the kill_chain_phases property of Technique, Malware, and Tool objects to map them to their applicable tactic(s)." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:MarkingDefinitionTypeEnum a owl:Class ;
    rdfs:label "MarkingDefinitionTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/MarkingDefinitionTypeEnum#tlp> <https://w3id.org/lmodel/attack/MarkingDefinitionTypeEnum#statement> ) ;
    skos:definition "Closed enumeration of ATT&CK marking definition types. ATT&CK uses two variants: TLP traffic-light protocol markings and plain text statement (copyright) markings." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/MarkingDefinitionTypeEnum#statement>,
        <https://w3id.org/lmodel/attack/MarkingDefinitionTypeEnum#tlp> .

attack:mutable_field a owl:DatatypeProperty ;
    rdfs:label "mutable_field" ;
    rdfs:range xsd:string ;
    skos:definition "The name of the analytic field or parameter that can be tuned by a defender to adapt it to their environment (e.g., 'TimeWindow', 'UserContext', 'PortRange', 'SubnetFilter'). Provides a clear identifier for the tunable aspect of the analytic." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:tlp a owl:ObjectProperty ;
    rdfs:label "tlp" ;
    rdfs:range attack:TlpLevelEnum ;
    skos:definition "The Traffic Light Protocol level assigned by this TLP marking definition. Must be one of the four standard TLP values: 'white', 'green', 'amber', 'red'. Each TLP level carries distinct sharing semantics governing how marked content may be further distributed by recipients." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_data_component_ref a owl:DatatypeProperty ;
    rdfs:label "x_mitre_data_component_ref" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^x-mitre-data-component--" ] ) ] ) ] ;
    skos:definition "The STIX ID of the x-mitre-data-component object that this log source reference is associated with. Links the analytic's required data collection to a specific data component's log source definition." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_data_source_ref a owl:DatatypeProperty ;
    rdfs:label "x_mitre_data_source_ref" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^x-mitre-data-source--" ] ) ] ) ] ;
    skos:definition "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. The STIX ID of the parent x-mitre-data-source object that this data component belongs to. Establishes the hierarchical source-to-component relationship. Superseded by explicit 'detects' relationships from DetectionStrategy objects." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_detection a owl:DatatypeProperty ;
    rdfs:label "x_mitre_detection" ;
    rdfs:range xsd:string ;
    skos:definition "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. Narrative text describing analytic strategies that defenders can use to identify whether an adversary has used this technique. Superseded by Detection Strategies and Analytics referenced via 'detects' relationships." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_first_seen_citation a owl:DatatypeProperty ;
    rdfs:label "x_mitre_first_seen_citation" ;
    rdfs:range xsd:string ;
    skos:definition "One or more inline citation references documenting the original sources that established when this campaign was first observed. Each citation references a source_name from the object's external_references array. Multiple citations are concatenated without separators: '(Citation: Source1)(Citation: Source2)'. This property is required on all Campaign objects." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_is_subtechnique a owl:DatatypeProperty ;
    rdfs:label "x_mitre_is_subtechnique" ;
    rdfs:range xsd:boolean ;
    skos:definition "Boolean flag indicating whether this attack-pattern is a sub-technique (true) or a top-level technique (false). Sub-techniques represent more specific implementations of parent techniques with ATT&CK IDs in the format T####.###. Each sub-technique is connected to its parent via a 'subtechnique-of' relationship where this object is the source_ref and the parent technique is the target_ref. Sub-techniques inherit all of their parent's tactics and must use a subset of the parent's platforms." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_last_seen_citation a owl:DatatypeProperty ;
    rdfs:label "x_mitre_last_seen_citation" ;
    rdfs:range xsd:string ;
    skos:definition "One or more inline citation references documenting the original sources that established when this campaign was last observed. Each citation references a source_name from the object's external_references array. Multiple citations are concatenated without separators: '(Citation: Source1)(Citation: Source2)'. This property is required on all Campaign objects." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_network_requirements a owl:DatatypeProperty ;
    rdfs:label "x_mitre_network_requirements" ;
    rdfs:range xsd:boolean ;
    skos:definition "Boolean indicating whether this technique requires network connectivity as a precondition for execution. When true, the adversary must have network access to the target environment for the technique to be applicable." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_old_attack_id a owl:DatatypeProperty ;
    rdfs:label "x_mitre_old_attack_id" ;
    rdfs:range xsd:string ;
    skos:definition "A legacy ATT&CK ID previously assigned to this object before a knowledge base restructuring or domain migration event. Format mirrors the current ATT&CK ID format but from the prior numbering scheme (e.g., \"MOB-T1001\" for a mobile technique previously in the pre-unification Mobile ATT&CK dataset)." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_remote_support a owl:DatatypeProperty ;
    rdfs:label "x_mitre_remote_support" ;
    rdfs:range xsd:boolean ;
    skos:definition "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. Boolean indicating whether this technique can be used to execute commands or payloads on a remote system without requiring local presence. When true, the technique supports remote execution scenarios." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_shortname a owl:ObjectProperty ;
    rdfs:label "x_mitre_shortname" ;
    rdfs:range attack:AttackTacticShortNameEnum ;
    skos:definition "The machine-readable short identifier for an ATT&CK tactic. Used to map techniques to their associated tactic: a technique's kill_chain_phases entry uses this value as its phase_name when the kill_chain_name matches the tactic's domain. For example, the 'Initial Access' tactic has x_mitre_shortname 'initial-access'. Must be unique across all tactics within a domain." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

stix:ExternalReference a owl:Class ;
    rdfs:label "ExternalReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:external_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:source_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:HashesType ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:anyURI [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^\\w+:" ] ) ] ) ] ;
            owl:onProperty stix:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:source_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:hashes ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:source_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:external_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:external_id ],
        stix:CommonSchemaComponent ;
    skos:definition "External references are used to describe pointers to information represented outside of STIX. " ;
    skos:editorialNote "Upstream JSON Schema uses oneOf branches keyed by source_name; exact branch logic is delegated to validator tooling." ;
    skos:exactMatch unified_cyber_ontology:ExternalReference ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: oneOf validator_hint: external-reference-branch-validation jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/external-reference.json" .

stix:StixEntity a owl:Class ;
    rdfs:label "StixEntity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:type ] ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:abstract a owl:DatatypeProperty ;
    rdfs:label "abstract" ;
    rdfs:range xsd:string ;
    skos:definition "Brief summary text." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:account_created a owl:DatatypeProperty ;
    rdfs:label "account_created" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Account creation timestamp." ;
