            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:published ],
        [ a owl:Restriction ;
