                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_contents ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        attack:AttackObject ;
    skos:definition """Collections are versioned snapshots of an ATT&CK dataset grouping all STIX objects that constitute a specific release of an ATT&CK domain or curated subset. ATT&CK distributes one collection per domain per release.
The x_mitre_contents property provides an ordered list of versioned object references (ID + modified timestamp pairs) enumerating every STIX object included in this collection. This precise versioning allows consumers to reconstruct the exact state of the knowledge base at any given ATT&CK release.
Bundle validation: In a distributing STIX Bundle, the Collection must be the first object in the bundle's 'objects' array. All STIX IDs referenced in x_mitre_contents must be present as objects within the same bundle.
See the ATT&CK Workbench collections documentation for detailed design rationale and usage guidance.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:stix_type "x-mitre-collection" .

attack:DataComponent a owl:Class ;
    rdfs:label "DataComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-data-component--" ] ) ] ;
