attack:MutableElement a owl:Class ;
    rdfs:label "MutableElement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:mutable_field ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:mutable_field ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:mutable_field ] ;
    skos:definition "An environment-tunable parameter within an ATT&CK analytic. Mutable elements identify specific fields in the detection logic that defenders can adjust to adapt the analytic to their operational environment without altering its fundamental detection behavior. For example, 'TimeWindow' could be tuned to match an organization's normal authentication patterns, or 'PortRange' adjusted to reflect monitored network segments." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

