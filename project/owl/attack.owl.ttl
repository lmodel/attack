attack:x_mitre_modified_by_ref a owl:DatatypeProperty ;
    rdfs:label "x_mitre_modified_by_ref" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
    skos:definition "The STIX ID of the identity object that created the current version of this object. In practice, always references MITRE's canonical identity object: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5. May differ from created_by_ref if the object was originally created by a third party and subsequently adopted or updated by MITRE." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "validator_hint: must-match-mitre-identity-id" .

xsd:string a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^([a-z][a-z0-9]*)+(-[a-z0-9]+)*-?$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^(\\d{1,2})\\.(\\d{1,2})$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^(\\(Citation:[^)]+\\))+$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[a-z][a-z0-9-]*--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] .


