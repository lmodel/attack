stix:aliases a owl:DatatypeProperty ;
    rdfs:label "aliases" ;
    rdfs:range xsd:string ;
    skos:definition "Alternative names for the object." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

attack:AttackObject a owl:Class ;
    rdfs:label "AttackObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_attack_spec_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_old_attack_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:modified ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:spec_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:modified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:created ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:spec_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_old_attack_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_attack_spec_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty attack:x_mitre_deprecated ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:spec_version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_deprecated ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_old_attack_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_attack_spec_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_deprecated ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:modified ],
        stix:Core ;
    skos:definition "Abstract base class for all versioned ATT&CK objects (SDOs and SROs). Extends the STIX Core (Common Properties) object with ATT&CK-specific universal properties: the required x_mitre_attack_spec_version (which ATT&CK specification the object conforms to), x_mitre_version (the object's content version), and optional x_mitre_deprecated and x_mitre_old_attack_id for lifecycle management. The name property inherited from StixEntity is required on all AttackObject subclasses (except Relationship, where it is not present)." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:note "Corresponds to attackBaseDomainObjectSchema / attackBaseRelationshipObjectSchema in the ATT&CK Data Model TypeScript implementation. Relationship objects additionally omit 'name' and 'x_mitre_version'; see AttackRelationship for those constraints. MarkingDefinition additionally omits 'modified', 'x_mitre_attack_spec_version', 'x_mitre_version', and 'x_mitre_deprecated'; see AttackMarkingDefinition." .

stix:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:closeMatch unified_cyber_ontology:description ;
    skos:definition "Human-readable description." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:range xsd:string ;
    skos:definition "Version string." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

