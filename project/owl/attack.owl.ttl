            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-detection-strategy$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^x-mitre-analytic--" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_analytic_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-detection-strategy--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_analytic_refs ],
        attack:AttackObject ;
    skos:definition """Detection Strategies define high-level, platform-agnostic approaches for detecting specific adversary techniques. They function as containers organizing one or more platform-specific Analytics (x-mitre-analytic objects) into cohesive detection methodologies, describing what data to collect and what behavioral patterns to look for.
Detection Strategies were introduced in ATT&CK Specification 3.3.0 as part of the new detection framework, superseding the deprecated x-mitre-data-source and x-mitre-data-component approach for technique detection.
A Detection Strategy links to its implementing analytics via x_mitre_analytic_refs. Analytics in turn link back to data components via x_mitre_log_source_references, creating a complete detection chain from technique to observable log event.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:attack_id_format "DET####" ;
    attack:stix_type "x-mitre-detection-strategy" .

