    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:imphash a owl:DatatypeProperty ;
    rdfs:label "imphash" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the special import hash, or 'imphash', calculated for the PE binary." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:inhibit_any_policy a owl:DatatypeProperty ;
    rdfs:label "inhibit_any_policy" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the number of additional certificates that may appear in the path before anyPolicy is no longer permitted." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:integrity_level a owl:ObjectProperty ;
    rdfs:label "integrity_level" ;
    rdfs:range attack:WindowsIntegrityLevelEnum ;
    skos:definition "Specifies the Windows integrity level of the process." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:ipfix a owl:DatatypeProperty ;
    rdfs:label "ipfix" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies any IP Flow Information Export (IPFIX) data for the traffic." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_active a owl:DatatypeProperty ;
    rdfs:label "is_active" ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates traffic is still active." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_blocking a owl:DatatypeProperty ;
    rdfs:label "is_blocking" ;
    rdfs:range xsd:boolean ;
    skos:definition "Specifies whether the socket is in blocking mode." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_disabled a owl:DatatypeProperty ;
    rdfs:label "is_disabled" ;
    rdfs:range xsd:boolean ;
    skos:definition "Disabled account flag." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_family a owl:DatatypeProperty ;
    rdfs:label "is_family" ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates if malware object is a family." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_hidden a owl:DatatypeProperty ;
    rdfs:label "is_hidden" ;
    rdfs:range xsd:boolean ;
    skos:definition "Specifies whether the process is hidden." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_listening a owl:DatatypeProperty ;
    rdfs:label "is_listening" ;
    rdfs:range xsd:boolean ;
    skos:definition "Specifies whether the socket is in listening mode." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_multipart a owl:DatatypeProperty ;
    rdfs:label "is_multipart" ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether the email body contains multiple MIME parts." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_optimized a owl:DatatypeProperty ;
    rdfs:label "is_optimized" ;
    rdfs:range xsd:boolean ;
    skos:definition "Specifies whether the PDF file has been optimized." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_privileged a owl:DatatypeProperty ;
    rdfs:label "is_privileged" ;
    rdfs:range xsd:boolean ;
    skos:definition "Privileged account flag." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_self_signed a owl:DatatypeProperty ;
    rdfs:label "is_self_signed" ;
    rdfs:range xsd:boolean ;
    skos:definition "Specifies whether the certificate is self-signed." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:is_service_account a owl:DatatypeProperty ;
    rdfs:label "is_service_account" ;
    rdfs:range xsd:boolean ;
    skos:definition "Service account flag." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:issuer a owl:DatatypeProperty ;
    rdfs:label "issuer" ;
    rdfs:range xsd:string ;
    skos:definition "Certificate issuer." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:issuer_alternative_name a owl:DatatypeProperty ;
    rdfs:label "issuer_alternative_name" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the additional identities to be bound to the issuer of the certificate." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:key a owl:DatatypeProperty ;
    rdfs:label "key" ;
    rdfs:range xsd:string ;
    skos:definition "Registry key path." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:key_usage a owl:DatatypeProperty ;
    rdfs:label "key_usage" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies a multi-valued extension consisting of a list of names of the permitted key usages." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:kill_chain_name a owl:DatatypeProperty ;
    rdfs:label "kill_chain_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the kill chain." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:last_observed a owl:DatatypeProperty ;
    rdfs:label "last_observed" ;
    rdfs:range xsd:dateTime ;
    skos:definition "End of observation window." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:latitude a owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive -90 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 90 ] ) ] ) ] ;
    skos:definition "Latitude in decimal degrees." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:loader_flags_hex a owl:DatatypeProperty ;
    rdfs:label "loader_flags_hex" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the reserved loader flags." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_format: hex" .

stix:longitude a owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive -180 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 180 ] ) ] ) ] ;
    skos:definition "Longitude in decimal degrees." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:machine_hex a owl:DatatypeProperty ;
    rdfs:label "machine_hex" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the type of target machine." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_format: hex" .

stix:magic_hex a owl:DatatypeProperty ;
    rdfs:label "magic_hex" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the unsigned integer that indicates the type of the PE binary (e.g. PE32 or PE32+)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_format: hex" .

stix:magic_number_hex a owl:DatatypeProperty ;
    rdfs:label "magic_number_hex" ;
    rdfs:range xsd:string ;
    skos:definition "Hex magic number." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:major_image_version a owl:DatatypeProperty ;
    rdfs:label "major_image_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the major version number of the image." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:major_linker_version a owl:DatatypeProperty ;
    rdfs:label "major_linker_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the linker major version number." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:major_os_version a owl:DatatypeProperty ;
    rdfs:label "major_os_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the major version number of the required operating system." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:major_subsystem_version a owl:DatatypeProperty ;
    rdfs:label "major_subsystem_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the major version number of the subsystem." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:marking_ref a owl:DatatypeProperty ;
    rdfs:label "marking_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Marking-definition reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:message_body_data_ref a owl:DatatypeProperty ;
    rdfs:label "message_body_data_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the data contained in the HTTP message body, as a reference to an Artifact object." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:message_body_length a owl:DatatypeProperty ;
    rdfs:label "message_body_length" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the length of the HTTP message body, if included in the request." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:message_id a owl:DatatypeProperty ;
    rdfs:label "message_id" ;
    rdfs:range xsd:string ;
    skos:definition "Message identifier field." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:minor_image_version a owl:DatatypeProperty ;
    rdfs:label "minor_image_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the minor version number of the image." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:minor_linker_version a owl:DatatypeProperty ;
    rdfs:label "minor_linker_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the linker minor version number." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:minor_os_version a owl:DatatypeProperty ;
    rdfs:label "minor_os_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the minor version number of the required operating system." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:minor_subsystem_version a owl:DatatypeProperty ;
    rdfs:label "minor_subsystem_version" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the minor version number of the subsystem." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:modified a owl:DatatypeProperty ;
    rdfs:label "modified" ;
    rdfs:range xsd:dateTime ;
    skos:closeMatch unified_cyber_ontology:modifiedTime ;
    skos:definition "Modification timestamp." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:modified_time a owl:DatatypeProperty ;
    rdfs:label "modified_time" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Modification timestamp." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:name_constraints a owl:DatatypeProperty ;
    rdfs:label "name_constraints" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies a namespace within which all subject names in subsequent certificates in a certification path must be located." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:name_enc a owl:DatatypeProperty ;
    rdfs:label "name_enc" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[a-zA-Z0-9/\\.+_:-]{2,250}$" ] ) ] ) ] ;
    skos:definition "Encoding for a name field." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:number a owl:DatatypeProperty ;
    rdfs:label "number" ;
    rdfs:range xsd:integer ;
    skos:definition "Numeric identifier value." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:number_observed a owl:DatatypeProperty ;
    rdfs:label "number_observed" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 999999999 ] ) ] ) ] ;
    skos:definition "Number of observations." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:number_of_rva_and_sizes a owl:DatatypeProperty ;
    rdfs:label "number_of_rva_and_sizes" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the number of data-directory entries in the remainder of the optional header." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:number_of_sections a owl:DatatypeProperty ;
    rdfs:label "number_of_sections" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the number of sections in the PE binary, as a non-negative integer." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:number_of_subkeys a owl:DatatypeProperty ;
    rdfs:label "number_of_subkeys" ;
    rdfs:range xsd:integer ;
    skos:definition "Number of registry subkeys." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:number_of_symbols a owl:DatatypeProperty ;
    rdfs:label "number_of_symbols" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the number of entries in the symbol table of the PE binary, as a non-negative integer." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:objective a owl:DatatypeProperty ;
    rdfs:label "objective" ;
    rdfs:range xsd:string ;
    skos:definition "Campaign objective." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:operating_system_ref a owl:DatatypeProperty ;
    rdfs:label "operating_system_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Operating system software reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:opinion a owl:ObjectProperty ;
    rdfs:label "opinion" ;
    rdfs:range attack:OpinionEnum ;
    skos:definition "Opinion value." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:optional_header a owl:ObjectProperty ;
    rdfs:label "optional_header" ;
    rdfs:range stix:WindowsPEOptionalHeaderType ;
    skos:definition "Specifies the PE optional header of the PE binary." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:owner_sid a owl:DatatypeProperty ;
    rdfs:label "owner_sid" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the Security ID (SID) value of the owner of the process." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:parent_directory_ref a owl:DatatypeProperty ;
    rdfs:label "parent_directory_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Parent directory reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:parent_ref a owl:DatatypeProperty ;
    rdfs:label "parent_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Parent process reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:path a owl:DatatypeProperty ;
    rdfs:label "path" ;
    rdfs:range xsd:string ;
    skos:definition "Filesystem path." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:path_enc a owl:DatatypeProperty ;
    rdfs:label "path_enc" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[a-zA-Z0-9/\\.+_:-]{2,250}$" ] ) ] ) ] ;
    skos:definition "Encoding used for a filesystem path." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pattern a owl:DatatypeProperty ;
    rdfs:label "pattern" ;
    rdfs:range xsd:string ;
    skos:definition "The detection pattern for this indicator." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "validator_hint: parse-with-stix-pattern-antlr-grammar" ;
    skos:relatedMatch unified_cyber_ontology:hasFacet .

stix:pattern_type a owl:DatatypeProperty ;
    rdfs:label "pattern_type" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( [ a rdfs:Datatype ;
                        owl:unionOf ( attack:PatternTypeOv xsd:string ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[a-z0-9\\-]+$" ] ) ] ) ] ;
    skos:definition "The type of pattern used in this indicator." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: PatternTypeOv" ;
    skos:relatedMatch unified_cyber_ontology:hasFacet .

stix:pattern_version a owl:DatatypeProperty ;
    rdfs:label "pattern_version" ;
    rdfs:range xsd:string ;
    skos:definition "The version of the pattern that is used." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:relatedMatch unified_cyber_ontology:specVersion .

stix:payload_bin a owl:DatatypeProperty ;
    rdfs:label "payload_bin" ;
    rdfs:range xsd:string ;
    skos:definition "Base64 binary payload." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pdfid0 a owl:DatatypeProperty ;
    rdfs:label "pdfid0" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the first file identifier found for the PDF file." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pdfid1 a owl:DatatypeProperty ;
    rdfs:label "pdfid1" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the second file identifier found for the PDF file." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pe_section_hashes a owl:ObjectProperty ;
    rdfs:label "pe_section_hashes" ;
    rdfs:range stix:HashesType ;
    skos:definition "Specifies any hashes computed over the section." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pe_section_name a owl:DatatypeProperty ;
    rdfs:label "pe_section_name" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the name of the PE section." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pe_section_size a owl:DatatypeProperty ;
    rdfs:label "pe_section_size" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the PE section, in bytes." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pe_type a owl:DatatypeProperty ;
    rdfs:label "pe_type" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:WindowsPEBinaryTypeOv xsd:string ) ] ;
    skos:definition "Specifies the type of the PE binary. Open Vocabulary - windows-pebinary-type-ov" ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: WindowsPEBinaryTypeOv" .

stix:phase_name a owl:DatatypeProperty ;
    rdfs:label "phase_name" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the kill chain phase." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pid a owl:DatatypeProperty ;
    rdfs:label "pid" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the Process ID, or PID, of the process." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:pointer_to_symbol_table_hex a owl:DatatypeProperty ;
    rdfs:label "pointer_to_symbol_table_hex" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the file offset of the COFF symbol table." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_format: hex" .

stix:policy_constraints a owl:DatatypeProperty ;
    rdfs:label "policy_constraints" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies any constraints on path validation for certificates issued to CAs." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:policy_mappings a owl:DatatypeProperty ;
    rdfs:label "policy_mappings" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies one or more pairs of OIDs; each pair includes an issuerDomainPolicy and a subjectDomainPolicy." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:postal_code a owl:DatatypeProperty ;
    rdfs:label "postal_code" ;
    rdfs:range xsd:string ;
    skos:definition "Postal code." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:precision a owl:DatatypeProperty ;
    rdfs:label "precision" ;
    rdfs:range xsd:float ;
    skos:definition "Coordinate precision in meters." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:priority a owl:DatatypeProperty ;
    rdfs:label "priority" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the current priority class of the process in Windows." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:private_key_usage_period_not_after a owl:DatatypeProperty ;
    rdfs:label "private_key_usage_period_not_after" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Specifies the date on which the validity period ends for the private key, if it is different from the validity period of the certificate." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:private_key_usage_period_not_before a owl:DatatypeProperty ;
    rdfs:label "private_key_usage_period_not_before" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Specifies the date on which the validity period begins for the private key, if it is different from the validity period of the certificate." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:product a owl:DatatypeProperty ;
    rdfs:label "product" ;
    rdfs:range xsd:string ;
    skos:definition "Malware analysis product name." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:published a owl:DatatypeProperty ;
    rdfs:label "published" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Timestamp when a report was published." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:raw_email_ref a owl:DatatypeProperty ;
    rdfs:label "raw_email_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Reference to raw email artifact." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:region a owl:DatatypeProperty ;
    rdfs:label "region" ;
    rdfs:range xsd:string ;
    skos:definition "Geographic region." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:registry_value_data a owl:DatatypeProperty ;
    rdfs:label "registry_value_data" ;
    rdfs:range xsd:string ;
    skos:definition "Registry value data content." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:registry_value_data_type a owl:ObjectProperty ;
    rdfs:label "registry_value_data_type" ;
    rdfs:range attack:RegistryDataTypeEnum ;
    skos:definition "Registry value data type." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:registry_value_name a owl:DatatypeProperty ;
    rdfs:label "registry_value_name" ;
    rdfs:range xsd:string ;
    skos:definition "Registry value name." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:relationship_type a owl:DatatypeProperty ;
    rdfs:label "relationship_type" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[a-z0-9\\-]+$" ] ) ] ) ] ;
    skos:definition "Name of the relationship type." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:relatedMatch unified_cyber_ontology:state .

stix:request_header a owl:DatatypeProperty ;
    rdfs:label "request_header" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies all of the HTTP header fields that may be found in the HTTP client request." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: patternProperties validator_hint: validate-http-request-header-dictionary" .

stix:request_method a owl:DatatypeProperty ;
    rdfs:label "request_method" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the HTTP method portion of the HTTP request line." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:request_value a owl:DatatypeProperty ;
    rdfs:label "request_value" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the value (typically a resource path) portion of the HTTP request line." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:request_version a owl:DatatypeProperty ;
    rdfs:label "request_version" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the HTTP version portion of the HTTP request line." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:result a owl:DatatypeProperty ;
    rdfs:label "result" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:MalwareAvResultOv xsd:string ) ] ;
    skos:definition "Malware analysis result value (malware-av-result-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: MalwareAvResultOv" .

stix:result_name a owl:DatatypeProperty ;
    rdfs:label "result_name" ;
    rdfs:range xsd:string ;
    skos:definition "Analysis result name." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:revoked a owl:DatatypeProperty ;
    rdfs:label "revoked" ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether this object has been revoked." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:rir a owl:DatatypeProperty ;
    rdfs:label "rir" ;
    rdfs:range xsd:string ;
    skos:definition "Regional Internet Registry name." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sample_ref a owl:DatatypeProperty ;
    rdfs:label "sample_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Analysis subject sample reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:schema a owl:DatatypeProperty ;
    rdfs:label "schema" ;
    rdfs:range xsd:string ;
    skos:definition "Extension schema definition or URL." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:section_alignment a owl:DatatypeProperty ;
    rdfs:label "section_alignment" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the alignment (in bytes) of PE sections when they are loaded into memory." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sender_ref a owl:DatatypeProperty ;
    rdfs:label "sender_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Sender reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:serial_number a owl:DatatypeProperty ;
    rdfs:label "serial_number" ;
    rdfs:range xsd:string ;
    skos:definition "X509 serial number." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:service_name a owl:DatatypeProperty ;
    rdfs:label "service_name" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the name of the service." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:service_status a owl:ObjectProperty ;
    rdfs:label "service_status" ;
    rdfs:range attack:WindowsServiceStatusEnum ;
    skos:definition "Specifies the current status of the service." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:service_type a owl:ObjectProperty ;
    rdfs:label "service_type" ;
    rdfs:range attack:WindowsServiceTypeEnum ;
    skos:definition "Specifies the type of the service." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:shell a owl:DatatypeProperty ;
    rdfs:label "shell" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the account's command shell." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sid a owl:DatatypeProperty ;
    rdfs:label "sid" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the security ID (SID) value assigned to the file." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sighting_of_ref a owl:DatatypeProperty ;
    rdfs:label "sighting_of_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Reference to the object being sighted." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:signature_algorithm a owl:DatatypeProperty ;
    rdfs:label "signature_algorithm" ;
    rdfs:range xsd:string ;
    skos:definition "X509 signature algorithm." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size a owl:DatatypeProperty ;
    rdfs:label "size" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Object size in bytes." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_code a owl:DatatypeProperty ;
    rdfs:label "size_of_code" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the code (text) section. If there are multiple such sections, this refers to the sum of the sizes of each section." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_headers a owl:DatatypeProperty ;
    rdfs:label "size_of_headers" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the combined size of the MS-DOS, PE header, and section headers, rounded to a multiple of the value specified in file_alignment." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_heap_commit a owl:DatatypeProperty ;
    rdfs:label "size_of_heap_commit" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the local heap space to commit." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_heap_reserve a owl:DatatypeProperty ;
    rdfs:label "size_of_heap_reserve" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the local heap space to reserve." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_image a owl:DatatypeProperty ;
    rdfs:label "size_of_image" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size, in bytes, of the image, including all headers, as the image is loaded in memory." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_initialized_data a owl:DatatypeProperty ;
    rdfs:label "size_of_initialized_data" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the initialized data section. If there are multiple such sections, this refers to the sum of the sizes of each section." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_optional_header a owl:DatatypeProperty ;
    rdfs:label "size_of_optional_header" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the optional header of the PE binary." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_stack_commit a owl:DatatypeProperty ;
    rdfs:label "size_of_stack_commit" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the stack to commit." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_stack_reserve a owl:DatatypeProperty ;
    rdfs:label "size_of_stack_reserve" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the stack to reserve." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:size_of_uninitialized_data a owl:DatatypeProperty ;
    rdfs:label "size_of_uninitialized_data" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Specifies the size of the uninitialized data section. If there are multiple such sections, this refers to the sum of the sizes of each section." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:socket_descriptor a owl:DatatypeProperty ;
    rdfs:label "socket_descriptor" ;
    rdfs:range xsd:integer ;
    skos:definition "Specifies the socket file descriptor value associated with the socket." ;
