    skos:definition "The IPv4 Address Object represents one or more IPv4 addresses expressed using CIDR notation. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/ipv4-addr.json" .

