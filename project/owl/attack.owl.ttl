    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ProcessorArchitectureOv xsd:string ) ] ;
    skos:definition "Open-vocabulary processor architectures (processor-architecture-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ProcessorArchitectureOv" .

stix:bcc_refs a owl:DatatypeProperty ;
