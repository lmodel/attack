stix:Timestamp a owl:Class ;
    rdfs:label "Timestamp" ;
    rdfs:subClassOf stix:CommonSchemaComponent ;
    skos:definition "Represents timestamps across the CTI specifications. The format is an RFC3339 timestamp, with a required timezone specification of 'Z'. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_type: string jsonschema_pattern: \"^[0-9]{4}-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9]|60)(\\\\.[0-9]+)?Z$\" jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/timestamp.json" .

