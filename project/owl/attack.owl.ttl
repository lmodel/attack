    skos:definition "Subject public key algorithm." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:subject_public_key_exponent a owl:DatatypeProperty ;
    rdfs:label "subject_public_key_exponent" ;
    rdfs:range xsd:integer ;
    skos:definition "Subject public key exponent." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:subject_public_key_modulus a owl:DatatypeProperty ;
    rdfs:label "subject_public_key_modulus" ;
    rdfs:range xsd:string ;
    skos:definition "Subject public key modulus." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:submitted a owl:DatatypeProperty ;
    rdfs:label "submitted" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Malware sample submission timestamp." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:subsystem_hex a owl:DatatypeProperty ;
    rdfs:label "subsystem_hex" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the subsystem (e.g., GUI, device driver, etc.) that is required to run this image." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_format: hex" .

stix:summary a owl:DatatypeProperty ;
    rdfs:label "summary" ;
    rdfs:range xsd:boolean ;
    skos:definition "The summary property indicates whether the Sighting should be considered summary data." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:swid a owl:DatatypeProperty ;
    rdfs:label "swid" ;
    rdfs:range xsd:string ;
    skos:definition "SWID tag value." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:target_ref a owl:DatatypeProperty ;
    rdfs:label "target_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Relationship target object reference." ;
