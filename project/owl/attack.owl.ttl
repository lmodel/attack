@prefix attack: <https://w3id.org/lmodel/attack/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix stix: <https://w3id.org/lmodel/stix/> .
@prefix unified_cyber_ontology: <https://w3id.org/lmodel/uco-master/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/attack.owl.ttl> a owl:Ontology ;
    rdfs:label "attack" ;
    dcterms:license "Apache-2.0" ;
    dcterms:source <https://mitre-attack.github.io/attack-data-model/schemas/> ;
    dcterms:title "ATT&CK" ;
    rdfs:seeAlso <https://attack.mitre.org>,
        <https://github.com/mitre-attack/attack-data-model>,
        <https://lmodel.github.io/attack> ;
    skos:definition """MITRE ATT&CK®: LinkML Schema
The ATT&CK knowledge base is modeled using the ATT&CK Data Model (ADM), a STIX 2.1-based
schema expressing adversary tactics, techniques, procedures (TTPs) and related objects.
This schema imports the STIX 2.1 LinkML schema and adds ATT&CK-specific classes, slots,
enumerations, and constraints.""" ;
    attack:attack_spec_version "3.3.0" ;
    attack:stix_version "2.1" .

attack:Analytic a owl:Class ;
    rdfs:label "Analytic" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-analytic$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_platforms ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_mutable_elements ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:MutableElement ;
            owl:onProperty attack:x_mitre_mutable_elements ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDomainEnum ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackPlatformEnum ;
            owl:onProperty attack:x_mitre_platforms ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:LogSourceReference ;
            owl:onProperty attack:x_mitre_log_source_references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-analytic--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_log_source_references ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        attack:AttackObject ;
    skos:definition """Analytics contain the concrete, platform-specific detection logic implementing a Detection Strategy for a specific operating environment. An analytic specifies the exact log data sources to query (via x_mitre_log_source_references), the detection logic or query pattern, and optionally defines tunable parameters (x_mitre_mutable_elements) allowing defenders to adapt it to their environment.
Each analytic targets exactly one platform (x_mitre_platforms maximum cardinality is 1). Multiple analytics may implement the same detection strategy, one per supported platform.
The detection chain is:
  DetectionStrategy (x_mitre_analytic_refs →)
    Analytic (x_mitre_log_source_references →)
      DataComponent (log_source name/channel →)
        detects →
          Technique""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:attack_id_format "AN####" ;
    attack:stix_type "x-mitre-analytic" .

attack:Asset a owl:Class ;
    rdfs:label "Asset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-asset--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackPlatformEnum ;
            owl:onProperty attack:x_mitre_platforms ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_related_assets ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_platforms ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^x-mitre-asset$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:RelatedAsset ;
            owl:onProperty attack:x_mitre_related_assets ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDomainEnum ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_sectors ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackAssetSectorEnum ;
            owl:onProperty attack:x_mitre_sectors ],
        attack:AttackObject ;
    skos:definition """Assets represent physical or logical systems, devices, and technologies within Operational Technology (OT) and Industrial Control System (ICS) environments that adversaries may target when attacking critical infrastructure. Assets are specific to the ICS ATT&CK domain.
Examples include Programmable Logic Controllers (PLCs), Remote Terminal Units (RTUs), Engineering Workstations, and Safety Instrumented Systems.
Related assets (x_mitre_related_assets) capture sector-specific alias names and variants of the same device type used across different industrial sectors. Asset sectors (x_mitre_sectors) scope the asset to one or more industry verticals.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:attack_id_format "A####" ;
    attack:stix_type "x-mitre-asset" .

attack:AttackBundle a owl:Class ;
    rdfs:label "AttackBundle" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^bundle$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:bundle_objects ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:bundle_objects ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^bundle--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        stix:Bundle ;
    skos:definition """An ATT&CK STIX Bundle is the top-level distribution container for an ATT&CK domain dataset. ATT&CK publishes one bundle per domain per release:
  - enterprise-attack  (Enterprise ATT&CK)
  - mobile-attack      (Mobile ATT&CK)
  - ics-attack         (ATT&CK for ICS)

A Bundle is NOT a STIX Object — it has no ATT&CK-specific versioning fields, no created_by_ref, and no marking definitions of its own. It serves purely as a JSON container grouping all objects that constitute a release.
ATT&CK Bundle structural requirements:
  1. The bundle MUST contain exactly one x-mitre-collection object.
  2. The x-mitre-collection MUST be the first object in the 'objects' array.
  3. All STIX IDs referenced in the collection's x_mitre_contents MUST be
     present in the bundle's 'objects' array (no dangling references).
  4. No duplicate STIX IDs are permitted within a bundle's objects array.

Note: A STIX Bundle Object is not a STIX Object (Section 7.1, STIX 2.1 spec). Objects within the bundle are not semantically related by virtue of sharing a container; all relationships are expressed via Relationship SRO objects.""" ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:stix_type "bundle" .

attack:AttackCampaign a owl:Class ;
    rdfs:label "AttackCampaign" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:first_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:first_seen ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackDomainEnum ;
            owl:onProperty attack:x_mitre_domains ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_last_seen_citation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_last_seen_citation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:revoked ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:aliases ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_first_seen_citation ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^campaign$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:last_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:last_seen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_first_seen_citation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:first_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:revoked ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^campaign--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_first_seen_citation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:last_seen ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:revoked ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5$" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_modified_by_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_last_seen_citation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:aliases ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:external_references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        attack:AttackObject ;
    skos:definition """Campaigns represent a grouping of adversary behaviors and resources with a common objective, occurring over a defined time period. A campaign may be attributed to one or more Groups via 'attributed-to' relationships.
Campaigns require mandatory temporal properties: first_seen and last_seen document when the campaign was active, and the corresponding citation properties (x_mitre_first_seen_citation, x_mitre_last_seen_citation) cite the intelligence sources that established those observations.
The aliases array is required; its first entry MUST match the campaign's name.""" ;
    skos:editorialNote "The class name 'attack:Campaign' collides with 'stix:Campaign', so renamed." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "validator_hint: first-aliases-entry-must-match-name validator_hint: citations-must-reference-valid-external-reference-source-names" ;
    attack:attack_id_format "C####" ;
    attack:stix_type "campaign" .

attack:AttackIdentity a owl:Class ;
    rdfs:label "AttackIdentity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:roles ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:contact_information ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:contact_information ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^identity$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:roles ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:sectors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:sectors ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:identity_class ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:identity_class ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^identity--" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:contact_information ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:identity_class ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:description ],
        attack:AttackObject ;
    skos:definition """The ATT&CK Identity object represents MITRE Corporation, the organization that maintains the ATT&CK knowledge base. The canonical ATT&CK Identity object has:
  STIX ID: identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5
  Name: The MITRE Corporation
  identity_class: organization

This Identity is referenced by created_by_ref and x_mitre_modified_by_ref throughout all ATT&CK objects to attribute creation and modification to MITRE.
Key differences from the standard ATT&CK object:
  - x_mitre_version is absent on Identity objects
  - Several STIX Identity properties (roles, sectors, contact_information) are
    defined in STIX but not actively used in ATT&CK Identity objects""" ;
    skos:editorialNote "The class name 'attack:Identity' collides with 'stix:Identity', so renamed." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    attack:canonical_id "identity--c78cb6e5-0c4b-4611-8297-d1b8b55e40b5" ;
    attack:stix_type "identity" .

attack:AttackMalware a owl:Class ;
    rdfs:label "AttackMalware" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:first_seen ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:x_mitre_contributors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:first_seen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:is_family ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
