                    owl:withRestrictions ( [ xsd:pattern "^location--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:postal_code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:latitude ],
