attack:RelatedAsset a owl:Class ;
    rdfs:label "RelatedAsset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:AttackAssetSectorEnum ;
            owl:onProperty attack:related_asset_sectors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:related_asset_sectors ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:description ] ;
    skos:definition "A sector-specific alias or variant name for a primary ATT&CK Asset object. Related assets capture how the same physical or logical device may be known by different names in different industrial contexts. For example, the primary asset 'Programmable Logic Controller (PLC)' may be called 'Field Controller' in the water treatment sector. Each related asset entry optionally scopes the alias to one or more industry sectors." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

