stix:subject_directory_attributes a owl:DatatypeProperty ;
    rdfs:label "subject_directory_attributes" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the identification attributes (e.g., nationality) of the subject." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:subject_key_identifier a owl:DatatypeProperty ;
    rdfs:label "subject_key_identifier" ;
    rdfs:range xsd:string ;
