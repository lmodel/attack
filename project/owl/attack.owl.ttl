stix:source_ref a owl:DatatypeProperty ;
    rdfs:label "source_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Relationship source object reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
