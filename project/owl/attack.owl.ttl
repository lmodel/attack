stix:src_port a owl:DatatypeProperty ;
    rdfs:label "src_port" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 65535 ] ) ] ) ] ;
    skos:definition "Source port number." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:src_ref a owl:DatatypeProperty ;
    rdfs:label "src_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Source observable reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:start a owl:DatatypeProperty ;
    rdfs:label "start" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Network traffic start time." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:start_time a owl:DatatypeProperty ;
    rdfs:label "start_time" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Start timestamp for temporal relationship validity." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:start_type a owl:ObjectProperty ;
    rdfs:label "start_type" ;
    rdfs:range attack:WindowsServiceStartEnum ;
    skos:definition "Specifies the start options defined for the service." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:startup_info a owl:DatatypeProperty ;
    rdfs:label "startup_info" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the STARTUP_INFO struct used by the process." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
