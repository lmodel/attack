    skos:definition "Reports are collections of threat intelligence focused on one or more topics, such as a description of a threat actor, malware, or attack technique, including context and related details. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sdos/report.json" ;
    skos:relatedMatch unified_cyber_ontology:Note .

