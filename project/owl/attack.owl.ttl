        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])(\\/(3[0-2]|[1-2][0-9]|[0-9]))?$" ] ) ] ) ] ;
            owl:onProperty stix:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:resolves_to_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^ipv4-addr$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:resolves_to_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:belongs_to_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:belongs_to_refs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        stix:CyberObservableObject ;
