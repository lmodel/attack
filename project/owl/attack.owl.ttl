        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:icmp_code_hex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:icmp_code_hex ],
        stix:CommonSchemaComponent ;
    skos:definition "The ICMP extension specifies a default extension for capturing network traffic properties specific to ICMP. Used as the value of the 'icmp-ext' key in a NetworkTraffic object's extensions dictionary." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "stix_extension_key: icmp-ext stix_parent_type: network-traffic jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/network-traffic.json" .

stix:Identifier a owl:Class ;
    rdfs:label "Identifier" ;
    rdfs:subClassOf stix:CommonSchemaComponent ;
    skos:definition "Represents identifiers across the CTI specifications. The format consists of the name of the top-level object being identified, followed by two dashes (--), followed by a UUIDv4. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "backed_by_type: stix_identifier jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/identifier.json" .

stix:Identity a owl:Class ;
    rdfs:label "Identity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^identity--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:sectors ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:IndustrySectorOv xsd:string ) ] ;
            owl:onProperty stix:sectors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:roles ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:ThreatActorRoleOv xsd:string ) ] ;
            owl:onProperty stix:roles ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:IdentityClassOv xsd:string ) ] ;
            owl:onProperty stix:identity_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:identity_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:contact_information ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:identity_class ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:contact_information ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:contact_information ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^identity$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        stix:StixDomainObject ;
    skos:definition "Identities can represent actual individuals, organizations, or groups (e.g., ACME, Inc.) as well as classes of individuals, organizations, or groups. " ;
    skos:exactMatch unified_cyber_ontology:Identity ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sdos/identity.json" .

stix:Incident a owl:Class ;
    rdfs:label "Incident" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^incident$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^incident--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        stix:StixDomainObject ;
    skos:definition "The Incident object in STIX 2.1 is a stub, to be expanded in future STIX 2 releases. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sdos/incident.json" .

stix:Indicator a owl:Class ;
    rdfs:label "Indicator" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^indicator--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:pattern_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:valid_from ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:valid_until ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:pattern_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:pattern_version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:valid_until ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:IndicatorTypeOv xsd:string ) ] ;
            owl:onProperty stix:indicator_types ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( attack:PatternTypeOv xsd:string ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^[a-z0-9\\-]+$" ] ) ] ) ] ;
            owl:onProperty stix:pattern_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
