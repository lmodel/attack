stix:kill_chain_phases a owl:ObjectProperty ;
    rdfs:label "kill_chain_phases" ;
    rdfs:range stix:KillChainPhase ;
    skos:definition "Kill chain phases associated with this object." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:object_refs a owl:DatatypeProperty ;
    rdfs:label "object_refs" ;
    rdfs:range xsd:string ;
    skos:definition "Referenced STIX objects." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:relatedMatch unified_cyber_ontology:externalReference .

stix:HashesType a owl:Class ;
    rdfs:label "HashesType" ;
    rdfs:subClassOf stix:CommonSchemaComponent ;
    skos:definition "The Hashes type represents one or more cryptographic hashes, as a special set of key/value pairs " ;
    skos:editorialNote "JSON Schema defines strict hash key patternProperties with algorithm-specific regex value constraints." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: patternProperties+additionalProperties=false validator_hint: validate-hash-key-specific-patterns jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/hashes-type.json" .

attack:x_mitre_platforms a owl:ObjectProperty ;
    rdfs:label "x_mitre_platforms" ;
    rdfs:range attack:AttackPlatformEnum ;
    skos:definition "The set of technology platforms or operating environments to which this ATT&CK object applies. Each value must be a supported ATT&CK platform identifier. Values within the array must be unique; duplicate platforms are not permitted." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "jsonschema_minItems: \"1\" validator_hint: no-duplicate-platforms" .

attack:x_mitre_version a owl:DatatypeProperty ;
    rdfs:label "x_mitre_version" ;
    rdfs:range xsd:string ;
    skos:definition "The version of this ATT&CK object content in 'major.minor' format, where both components are integers between 0 and 99. Incremented by ATT&CK whenever the substantive content of the object changes. Does not apply to relationship objects. Example: \"1.0\", \"12.5\"." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "absent_on: relationship, marking-definition" .

stix:hashes a owl:ObjectProperty ;
    rdfs:label "hashes" ;
    rdfs:range stix:HashesType ;
    skos:definition "Specifies a dictionary of hashes for the file or content." ;
    skos:exactMatch unified_cyber_ontology:hashes ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

