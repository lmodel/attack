        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:description ],
        [ a owl:Restriction ;
