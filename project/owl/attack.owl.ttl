        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:region ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:postal_code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:precision ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^location$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:precision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:longitude ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:country ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:administrative_area ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:street_address ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:street_address ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:city ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive -180 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 180 ] ) ] ) ] ;
            owl:onProperty stix:longitude ],
        [ a owl:Restriction ;
