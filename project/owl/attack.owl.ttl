attack:LogSource a owl:Class ;
    rdfs:label "LogSource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:log_source_channel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:log_source_channel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:log_source_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:log_source_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:log_source_channel ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:log_source_name ] ;
    skos:definition "A platform-specific log collection configuration embedded within a data component. Defines a specific log provider (name) and event category or channel identifier (channel) that together specify where to collect telemetry relevant to the parent data component's detection context. The (name, channel) pair must be unique within the x_mitre_log_sources array of a given data component." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:LogSourceReference a owl:Class ;
    rdfs:label "LogSourceReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:log_source_channel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:log_source_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:x_mitre_data_component_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty attack:log_source_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^x-mitre-data-component--" ] ) ] ) ] ;
            owl:onProperty attack:x_mitre_data_component_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:x_mitre_data_component_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty attack:log_source_channel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:log_source_channel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:log_source_name ] ;
    skos:definition "A reference linking an analytic to a specific data component and log source pair. Specifies both the data component by STIX ID and the precise (name, channel) log source within that component that provides the raw data consumed by the analytic. Each (x_mitre_data_component_ref, name, channel) tuple must be unique within the x_mitre_log_source_references array of a given analytic." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

