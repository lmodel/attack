stix:socket_type a owl:ObjectProperty ;
    rdfs:label "socket_type" ;
    rdfs:range attack:NetworkSocketTypeEnum ;
    skos:definition "Specifies the type of the socket." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:sophistication a owl:DatatypeProperty ;
    rdfs:label "sophistication" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ThreatActorSophisticationOv xsd:string ) ] ;
