    rdfs:label "AttackDomainEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/AttackDomainEnum#enterprise-attack> <https://w3id.org/lmodel/attack/AttackDomainEnum#mobile-attack> <https://w3id.org/lmodel/attack/AttackDomainEnum#ics-attack> ) ;
