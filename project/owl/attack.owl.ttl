    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ThreatActorSophisticationOv" .

stix:source_name a owl:DatatypeProperty ;
    rdfs:label "source_name" ;
    rdfs:range xsd:string ;
    skos:closeMatch unified_cyber_ontology:name ;
    skos:definition "Name of the external source." ;
