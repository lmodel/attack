                    owl:withRestrictions ( [ xsd:pattern "^mac-addr--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^mac-addr$" ] ) ] ;
            owl:onProperty attack:type ],
        stix:CyberObservableObject ;
    skos:closeMatch unified_cyber_ontology:MACAddress ;
    skos:definition "The MAC Address Object represents a single Media Access Control (MAC) address. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/mac-addr.json" .

stix:Malware a owl:Class ;
    rdfs:label "Malware" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:is_family ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:sample_refs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:first_seen ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:aliases ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:malware_types ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^malware$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:sample_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:implementation_languages ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:capabilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:first_seen ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^malware--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty stix:is_family ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:MalwareTypeOv xsd:string ) ] ;
            owl:onProperty stix:malware_types ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:ProcessorArchitectureOv xsd:string ) ] ;
            owl:onProperty stix:architecture_execution_envs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:kill_chain_phases ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:ImplementationLanguageOv xsd:string ) ] ;
            owl:onProperty stix:implementation_languages ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:KillChainPhase ;
            owl:onProperty stix:kill_chain_phases ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( attack:MalwareCapabilityOv xsd:string ) ] ;
            owl:onProperty stix:capabilities ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^software--" ] ) ] ) ] ;
            owl:onProperty stix:operating_system_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:architecture_execution_envs ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:last_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:is_family ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:last_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:operating_system_refs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:last_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:first_seen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:aliases ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        stix:StixDomainObject ;
    skos:definition "Malware is a type of TTP that is also known as malicious code and malicious software, refers to a program that is inserted into a system, usually covertly, with the intent of compromising the confidentiality, integrity, or availability of the victim's data, applications, or operating system (OS) or of otherwise annoying or disrupting the victim. " ;
    skos:editorialNote "JSON Schema includes oneOf semantics where name is required when is_family=true." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:narrowMatch unified_cyber_ontology:Software ;
    skos:note "jsonschema_rule: oneOf validator_hint: enforce-malware-family-name-constraint jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sdos/malware.json" .

