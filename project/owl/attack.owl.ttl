            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:source_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:start_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:stop_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^relationship$" ] ) ] ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:source_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:relationship_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:source_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty stix:start_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^[a-z0-9\\-]+$" ] ) ] ) ] ;
            owl:onProperty stix:relationship_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:start_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:target_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:target_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty attack:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:relationship_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:stop_time ],
        stix:StixRelationshipObject ;
    skos:definition "The Relationship object is used to link together two SDOs in order to describe how they are related to each other. " ;
    skos:editorialNote "source_ref and target_ref cannot target relationship, sighting, bundle, marking-definition, or language-content IDs." ;
    skos:exactMatch unified_cyber_ontology:Relationship ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: not validator_hint: relationship-ref-prefix-exclusion jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sros/relationship.json" .

stix:Report a owl:Class ;
    rdfs:label "Report" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:report_types ],
