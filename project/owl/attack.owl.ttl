            owl:minCardinality 0 ;
            owl:onProperty stix:region ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive -90 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 90 ] ) ] ) ] ;
            owl:onProperty stix:latitude ],
        stix:StixDomainObject ;
    skos:definition "A Location represents a geographic location. The location may be described as any, some or all of the following: region (e.g., North America), civic address (e.g. New York, US), latitude and longitude. " ;
    skos:editorialNote "JSON Schema requires one of region, country, or latitude+longitude and constrains precision usage." ;
    skos:exactMatch unified_cyber_ontology:Location ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_rule: anyOf+oneOf validator_hint: enforce-location-coordinate-and-region-rules jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/sdos/location.json" .

