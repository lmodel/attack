attack:AttackImpactTypeEnum a owl:Class ;
    rdfs:label "AttackImpactTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/AttackImpactTypeEnum#Availability> <https://w3id.org/lmodel/attack/AttackImpactTypeEnum#Integrity> ) ;
    skos:definition "Closed enumeration of impact type categories applicable to techniques in the Enterprise ATT&CK Impact tactic. Indicates whether the technique can be used to affect system availability, data integrity, or both." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/AttackImpactTypeEnum#Availability>,
        <https://w3id.org/lmodel/attack/AttackImpactTypeEnum#Integrity> .

attack:KillChainNameEnum a owl:Class ;
    rdfs:label "KillChainNameEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-attack> <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-mobile-attack> <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-ics-attack> ) ;
    skos:definition "Closed enumeration of ATT&CK kill chain identifiers used in kill_chain_phases. These three values correspond to the three ATT&CK domains and are used to map techniques to their associated tactics. The phase_name in each kill_chain_phase must match the x_mitre_shortname of the corresponding x-mitre-tactic object." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-attack>,
        <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-ics-attack>,
        <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-mobile-attack> .

attack:x_mitre_aliases a owl:DatatypeProperty ;
    rdfs:label "x_mitre_aliases" ;
    rdfs:range xsd:string ;
    skos:definition "ATT&CK-recognized alternative names or aliases for this software object (Malware or Tool). The first alias in the array MUST match the object's name property. This is the preferred alias field for ATT&CK software objects, distinct from the STIX-standard 'aliases' property which is present but not actively maintained in ATT&CK software objects." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "jsonschema_minItems: \"1\" validator_hint: first-alias-must-match-name" .

stix:GranularMarking a owl:Class ;
    rdfs:label "GranularMarking" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:lang ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^marking-definition--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" ] ) ] ) ] ;
            owl:onProperty stix:marking_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:marking_ref ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:selectors ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:lang ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:lang ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:marking_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:selectors ],
        stix:CommonSchemaComponent ;
    skos:definition "The granular-marking type defines how the list of marking-definition objects referenced by the marking_refs property to apply to a set of content identified by the list of selectors in the selectors property. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/granular-marking.json" .

stix:authors a owl:DatatypeProperty ;
    rdfs:label "authors" ;
    rdfs:range xsd:string ;
    skos:definition "Author list." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:belongs_to_refs a owl:DatatypeProperty ;
    rdfs:label "belongs_to_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References this observable belongs to." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:external_references a owl:ObjectProperty ;
    rdfs:label "external_references" ;
    rdfs:range stix:ExternalReference ;
    skos:closeMatch unified_cyber_ontology:externalReference ;
    skos:definition "External references to non-STIX information." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:goals a owl:DatatypeProperty ;
    rdfs:label "goals" ;
    rdfs:range xsd:string ;
    skos:definition "Threat actor goals." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:relatedMatch unified_cyber_ontology:hasFacet .

stix:roles a owl:DatatypeProperty ;
    rdfs:label "roles" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:ThreatActorRoleOv xsd:string ) ] ;
    skos:definition "Open-vocabulary threat actor roles." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: ThreatActorRoleOv" ;
    skos:relatedMatch unified_cyber_ontology:hasFacet .

stix:secondary_motivations a owl:DatatypeProperty ;
    rdfs:label "secondary_motivations" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:AttackMotivationOv xsd:string ) ] ;
    skos:definition "Secondary motivations (attack-motivation-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: AttackMotivationOv" .

attack:AttackTacticTypeEnum a owl:Class ;
    rdfs:label "AttackTacticTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/AttackTacticTypeEnum#Post-Adversary%20Device%20Access> <https://w3id.org/lmodel/attack/AttackTacticTypeEnum#Pre-Adversary%20Device%20Access> <https://w3id.org/lmodel/attack/AttackTacticTypeEnum#Without%20Adversary%20Device%20Access> ) ;
    skos:definition "Closed enumeration of tactic types for Mobile ATT&CK techniques (x_mitre_tactic_type). Indicates the adversary's device access model for executing the technique. Only used in the Mobile ATT&CK domain." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/AttackTacticTypeEnum#Post-Adversary%20Device%20Access>,
        <https://w3id.org/lmodel/attack/AttackTacticTypeEnum#Pre-Adversary%20Device%20Access>,
        <https://w3id.org/lmodel/attack/AttackTacticTypeEnum#Without%20Adversary%20Device%20Access> .

attack:WindowsPEBinaryTypeOv a owl:Class ;
    rdfs:label "WindowsPEBinaryTypeOv" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/WindowsPEBinaryTypeOv#exe> <https://w3id.org/lmodel/attack/WindowsPEBinaryTypeOv#dll> <https://w3id.org/lmodel/attack/WindowsPEBinaryTypeOv#sys> ) ;
    skos:definition "Open vocabulary for Windows PE binary type (windows-pebinary-type-ov). Suggested values are exe, dll, sys; additional string values are allowed." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: \"true\" jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/observables/file.json#/definitions/windows-pebinary-type-ov" ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/WindowsPEBinaryTypeOv#dll>,
        <https://w3id.org/lmodel/attack/WindowsPEBinaryTypeOv#exe>,
        <https://w3id.org/lmodel/attack/WindowsPEBinaryTypeOv#sys> .

stix:Core a owl:Class ;
    rdfs:label "Core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:revoked ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:spec_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:dateTime [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ) ] ) ] ;
            owl:onProperty stix:created ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:labels ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:lang ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 100 ] ) ] ) ] ;
            owl:onProperty stix:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:lang ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:extensions ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:labels ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:extensions ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:GranularMarking ;
            owl:onProperty stix:granular_markings ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:created ],
        [ a owl:Restriction ;
            owl:allValuesFrom attack:SpecVersionEnum ;
            owl:onProperty stix:spec_version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:object_marking_refs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:modified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:object_marking_refs ],
        [ a owl:Restriction ;
            owl:allValuesFrom stix:ExternalReference ;
            owl:onProperty stix:external_references ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:modified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:created_by_ref ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:revoked ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:created_by_ref ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty stix:spec_version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty stix:created ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty stix:revoked ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:lang ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:granular_markings ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty stix:external_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:dateTime [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "T\\d{2}:\\d{2}:\\d{2}\\.\\d{3,}Z$" ] ) ] ) ] ;
            owl:onProperty stix:modified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty stix:id ],
        stix:CommonSchemaComponent ;
    skos:definition "Common properties and behavior across all STIX Domain Objects and STIX Relationship Objects. " ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "jsonschema_source: https://github.com/oasis-open/cti-stix2-json-schemas/tree/master/schemas/common/core.json" .

attack:AttackEffectivePermissionsEnum a owl:Class ;
    rdfs:label "AttackEffectivePermissionsEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#Administrator> <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#SYSTEM> <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#User> <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#root> ) ;
    skos:definition "DEPRECATED in ATT&CK Specification v3.3.0. Will be removed in v4.0.0. Closed enumeration of the effective Windows or Unix permission levels that an adversary achieves after successfully exploiting a technique. Only four values are recognized." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#Administrator>,
        <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#SYSTEM>,
        <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#User>,
        <https://w3id.org/lmodel/attack/AttackEffectivePermissionsEnum#root> .

attack:MalwareAvResultOv a owl:Class ;
    rdfs:label "MalwareAvResultOv" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/MalwareAvResultOv#malicious> <https://w3id.org/lmodel/attack/MalwareAvResultOv#suspicious> <https://w3id.org/lmodel/attack/MalwareAvResultOv#benign> <https://w3id.org/lmodel/attack/MalwareAvResultOv#unknown> ) ;
    skos:definition "Open vocabulary for malware AV result (malware-av-result-ov). Additional string values are allowed." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: \"true\"" ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/MalwareAvResultOv#benign>,
        <https://w3id.org/lmodel/attack/MalwareAvResultOv#malicious>,
        <https://w3id.org/lmodel/attack/MalwareAvResultOv#suspicious>,
        <https://w3id.org/lmodel/attack/MalwareAvResultOv#unknown> .

attack:SpecVersionEnum a owl:Class ;
    rdfs:label "SpecVersionEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/SpecVersionEnum#2.0> <https://w3id.org/lmodel/attack/SpecVersionEnum#2.1> ) ;
    skos:definition "STIX specification versions allowed by the upstream JSON Schema." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/SpecVersionEnum#2.0>,
        <https://w3id.org/lmodel/attack/SpecVersionEnum#2.1> .

attack:TlpLevelEnum a owl:Class ;
    rdfs:label "TlpLevelEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/TlpLevelEnum#white> <https://w3id.org/lmodel/attack/TlpLevelEnum#green> <https://w3id.org/lmodel/attack/TlpLevelEnum#amber> <https://w3id.org/lmodel/attack/TlpLevelEnum#red> ) ;
    skos:definition "Closed enumeration of Traffic Light Protocol (TLP) sharing sensitivity levels. The four standard TLP levels control how broadly shared information can be distributed. ATT&CK uses canonical TLP marking definitions with fixed, immutable STIX IDs." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/TlpLevelEnum#amber>,
        <https://w3id.org/lmodel/attack/TlpLevelEnum#green>,
        <https://w3id.org/lmodel/attack/TlpLevelEnum#red>,
        <https://w3id.org/lmodel/attack/TlpLevelEnum#white> .

attack:WindowsIntegrityLevelEnum a owl:Class ;
    rdfs:label "WindowsIntegrityLevelEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#low> <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#medium> <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#high> <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#system> ) ;
    skos:definition "Windows process integrity level (trustworthiness) enumeration." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#high>,
        <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#low>,
        <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#medium>,
        <https://w3id.org/lmodel/attack/WindowsIntegrityLevelEnum#system> .

attack:WindowsServiceTypeEnum a owl:Class ;
    rdfs:label "WindowsServiceTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_KERNEL_DRIVER> <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_FILE_SYSTEM_DRIVER> <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_WIN32_OWN_PROCESS> <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_WIN32_SHARE_PROCESS> ) ;
    skos:definition "Windows service type enumeration." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    linkml:permissible_values <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_FILE_SYSTEM_DRIVER>,
        <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_KERNEL_DRIVER>,
        <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_WIN32_OWN_PROCESS>,
        <https://w3id.org/lmodel/attack/WindowsServiceTypeEnum#SERVICE_WIN32_SHARE_PROCESS> .

attack:log_source_channel a owl:DatatypeProperty ;
    rdfs:label "log_source_channel" ;
    rdfs:range xsd:string ;
    skos:definition "The specific log channel, event ID, or event category within the log source (e.g., '1' for Sysmon Process Creation event, 'SYSCALL' for Linux auditd, 'process' for macOS unified logs). Together with log_source_name, uniquely identifies a log collection configuration." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:log_source_name a owl:DatatypeProperty ;
    rdfs:label "log_source_name" ;
    rdfs:range xsd:string ;
    skos:definition "The log source provider or service name (e.g., 'sysmon', 'auditd', 'unified_logs', 'windows_security'). Together with log_source_channel, uniquely identifies a specific log collection configuration." ;
    skos:inScheme <https://w3id.org/lmodel/attack> .

attack:x_mitre_attack_spec_version a owl:DatatypeProperty ;
    rdfs:label "x_mitre_attack_spec_version" ;
    rdfs:range xsd:string ;
    skos:definition "The version of the ATT&CK Data Model specification used to construct this object, in MAJOR.MINOR.PATCH (semantic versioning) format. Helps consuming software determine whether the data format is supported. Objects lacking this property are assumed to conform to ATT&CK spec version 2.0.0. Refer to the ATT&CK CHANGELOG for all supported versions." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "absent_on: marking-definition, identity (x_mitre_version absent), relationship (x_mitre_version absent)" .

attack:x_mitre_deprecated a owl:DatatypeProperty ;
    rdfs:label "x_mitre_deprecated" ;
    rdfs:range xsd:boolean ;
    skos:definition "Boolean flag indicating that this ATT&CK object has been deprecated and should no longer be used in new analyses or tooling implementations. Deprecated objects are retained in the knowledge base for historical reference and legacy compatibility, but are not actively maintained with new information." ;
    skos:inScheme <https://w3id.org/lmodel/attack> ;
    skos:note "absent_on: marking-definition" .

stix:atime a owl:DatatypeProperty ;
    rdfs:label "atime" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Last access time." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:body a owl:DatatypeProperty ;
    rdfs:label "body" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies a string containing the email body. This field MAY only be used if is_multipart is false." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:contains_refs a owl:DatatypeProperty ;
    rdfs:label "contains_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References to contained objects." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:content_type a owl:DatatypeProperty ;
    rdfs:label "content_type" ;
    rdfs:range xsd:string ;
    skos:definition "Specifies the value of the 'Content-Type' header of the email message." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:created a owl:DatatypeProperty ;
    rdfs:label "created" ;
    rdfs:range xsd:dateTime ;
    skos:closeMatch unified_cyber_ontology:objectCreatedTime ;
    skos:definition "Creation timestamp." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:created_by_ref a owl:DatatypeProperty ;
    rdfs:label "created_by_ref" ;
    rdfs:range xsd:string ;
    skos:closeMatch unified_cyber_ontology:createdBy ;
    skos:definition "ID of the object that created this object." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:creator_user_ref a owl:DatatypeProperty ;
    rdfs:label "creator_user_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Creating user reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:ctime a owl:DatatypeProperty ;
    rdfs:label "ctime" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Creation time." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:granular_markings a owl:ObjectProperty ;
    rdfs:label "granular_markings" ;
    rdfs:range stix:GranularMarking ;
    skos:definition "Granular markings that apply to selected content." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:narrowMatch unified_cyber_ontology:objectMarking .

stix:lang a owl:DatatypeProperty ;
    rdfs:label "lang" ;
    rdfs:range xsd:string ;
    skos:definition "Language of textual properties." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:mime_type a owl:DatatypeProperty ;
    rdfs:label "mime_type" ;
    rdfs:range xsd:string ;
    skos:definition "MIME type value." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:mtime a owl:DatatypeProperty ;
    rdfs:label "mtime" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Last modification time." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:object_marking_refs a owl:DatatypeProperty ;
    rdfs:label "object_marking_refs" ;
    rdfs:range xsd:string ;
    skos:closeMatch unified_cyber_ontology:objectMarking ;
    skos:definition "Marking definition references applied to this object." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:object_modified a owl:DatatypeProperty ;
    rdfs:label "object_modified" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Referenced object modified timestamp." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:object_ref a owl:DatatypeProperty ;
    rdfs:label "object_ref" ;
    rdfs:range xsd:string ;
    skos:definition "Single object reference." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:primary_motivation a owl:DatatypeProperty ;
    rdfs:label "primary_motivation" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:AttackMotivationOv xsd:string ) ] ;
    skos:definition "Primary motivation (attack-motivation-ov)." ;
    skos:inScheme <https://w3id.org/lmodel/stix> ;
    skos:note "open_vocabulary: AttackMotivationOv" .

stix:resolves_to_refs a owl:DatatypeProperty ;
    rdfs:label "resolves_to_refs" ;
    rdfs:range xsd:string ;
    skos:definition "References this observable resolves to." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:resource_level a owl:DatatypeProperty ;
    rdfs:label "resource_level" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( attack:AttackResourceLevelOv xsd:string ) ] ;
    skos:definition "Threat actor resource level (attack-resource-level-ov)." ;
