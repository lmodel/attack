    skos:definition "Objects contained in a bundle." ;
    skos:inScheme <https://w3id.org/lmodel/stix> .

stix:capabilities a owl:DatatypeProperty ;
    rdfs:label "capabilities" ;
    rdfs:range [ a rdfs:Datatype ;
