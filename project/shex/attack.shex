# metamodel_version: 1.7.0
BASE <https://w3id.org/lmodel/attack/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX linkml: <https://w3id.org/linkml/>
PREFIX stix: <https://w3id.org/lmodel/stix/>


<AttackVersionString> xsd:string

<SemverString> xsd:string

<CitationString> xsd:string

linkml:String xsd:string

linkml:Integer xsd:integer

linkml:Boolean xsd:boolean

linkml:Float xsd:float

linkml:Double xsd:double

linkml:Decimal xsd:decimal

linkml:Time xsd:time

linkml:Date xsd:date

linkml:Datetime xsd:dateTime

linkml:DateOrDatetime linkml:DateOrDatetime

linkml:Uriorcurie IRI

linkml:Curie xsd:string

linkml:Uri IRI

linkml:Ncname xsd:string

linkml:Objectidentifier IRI

linkml:Nodeidentifier NONLITERAL

linkml:Jsonpointer xsd:string

linkml:Jsonpath xsd:string

linkml:Sparqlpath xsd:string

stix:StixIdentifier xsd:string

stix:StixTypeName xsd:string

stix:AlternateDataStreamType CLOSED {
    (  $stix:AlternateDataStreamType_tes (  &stix:CommonSchemaComponent_tes ;
          rdf:type [ stix:CommonSchemaComponent ] ? ;
          stix:ads_name @linkml:String ;
          stix:ads_size @linkml:Integer ? ;
          stix:ads_hashes @stix:HashesType ?
       ) ;
       rdf:type [ stix:AlternateDataStreamType ] ?
    )
}

<Analytic> CLOSED {
    (  $<Analytic_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ? ;
          <x_mitre_domains> [ <https://w3id.org/lmodel/attack/AttackDomainEnum#enterprise-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#mobile-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#ics-attack> ] + ;
          <x_mitre_platforms> [ <https://w3id.org/lmodel/attack/AttackPlatformEnum#Windows>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Linux> <https://w3id.org/lmodel/attack/AttackPlatformEnum#macOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Android> <https://w3id.org/lmodel/attack/AttackPlatformEnum#iOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Azure%20AD>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Google%20Workspace>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Office%20Suite>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#SaaS> <https://w3id.org/lmodel/attack/AttackPlatformEnum#IaaS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Containers>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#ESXi>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Identity%20Provider>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Network%20Devices>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#PRE> <https://w3id.org/lmodel/attack/AttackPlatformEnum#None>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Field%20Controller/RTU/PLC/IED>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Data%20Historian>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Engineering%20Workstation>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Control%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Human-Machine%20Interface>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Input/Output%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Safety%20Instrumented%20System/Protection%20Relay>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Embedded> ] * ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ? ;
          <x_mitre_log_source_references> @<LogSourceReference> * ;
          <x_mitre_mutable_elements> @<MutableElement> * ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:name @linkml:String ;
          stix:description @linkml:String ;
          stix:external_references @stix:ExternalReference + ;
          stix:created_by_ref @stix:StixIdentifier ;
          stix:object_marking_refs @stix:StixIdentifier +
       ) ;
       rdf:type [ <Analytic> ] ?
    )
}

stix:ArchiveExt CLOSED {
    (  $stix:ArchiveExt_tes (  &stix:CommonSchemaComponent_tes ;
          rdf:type [ stix:CommonSchemaComponent ] ? ;
          stix:contains_refs @stix:StixIdentifier + ;
          stix:comment @linkml:String ?
       ) ;
       rdf:type [ stix:ArchiveExt ] ?
    )
}

stix:Artifact CLOSED {
    (  $stix:Artifact_tes (  &stix:CyberObservableObject_tes ;
          rdf:type [ stix:CyberObservableObject ] ? ;
          stix:mime_type @linkml:String ? ;
          stix:payload_bin @linkml:String ? ;
          stix:url @linkml:Uriorcurie ? ;
          stix:hashes @stix:HashesType ? ;
          stix:encryption_algorithm @linkml:String ? ;
          stix:decryption_key @linkml:String ? ;
          stix:id @stix:StixIdentifier ;
          stix:type @stix:StixTypeName
       ) ;
       rdf:type [ stix:Artifact ] ?
    )
}

<Asset> CLOSED {
    (  $<Asset_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ? ;
          <x_mitre_domains> [ <https://w3id.org/lmodel/attack/AttackDomainEnum#enterprise-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#mobile-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#ics-attack> ] + ;
          <x_mitre_platforms> [ <https://w3id.org/lmodel/attack/AttackPlatformEnum#Windows>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Linux> <https://w3id.org/lmodel/attack/AttackPlatformEnum#macOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Android> <https://w3id.org/lmodel/attack/AttackPlatformEnum#iOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Azure%20AD>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Google%20Workspace>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Office%20Suite>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#SaaS> <https://w3id.org/lmodel/attack/AttackPlatformEnum#IaaS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Containers>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#ESXi>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Identity%20Provider>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Network%20Devices>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#PRE> <https://w3id.org/lmodel/attack/AttackPlatformEnum#None>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Field%20Controller/RTU/PLC/IED>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Data%20Historian>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Engineering%20Workstation>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Control%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Human-Machine%20Interface>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Input/Output%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Safety%20Instrumented%20System/Protection%20Relay>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Embedded> ] * ;
          <x_mitre_contributors> @linkml:String * ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ? ;
          <x_mitre_sectors> [ <https://w3id.org/lmodel/attack/AttackAssetSectorEnum#Electric>
             <https://w3id.org/lmodel/attack/AttackAssetSectorEnum#Water%20and%20Wastewater>
             <https://w3id.org/lmodel/attack/AttackAssetSectorEnum#Manufacturing>
             <https://w3id.org/lmodel/attack/AttackAssetSectorEnum#Rail>
             <https://w3id.org/lmodel/attack/AttackAssetSectorEnum#Maritime>
             <https://w3id.org/lmodel/attack/AttackAssetSectorEnum#General> ] * ;
          <x_mitre_related_assets> @<RelatedAsset> * ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:name @linkml:String ;
          stix:description @linkml:String ? ;
          stix:external_references @stix:ExternalReference + ;
          stix:created_by_ref @stix:StixIdentifier ;
          stix:object_marking_refs @stix:StixIdentifier +
       ) ;
       rdf:type [ <Asset> ] ?
    )
}

<AttackBundle> CLOSED {
    (  $<AttackBundle_tes> (  &stix:Bundle_tes ;
          rdf:type [ stix:Bundle ] ? ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:bundle_objects @stix:StixEntity +
       ) ;
       rdf:type [ <AttackBundle> ] ?
    )
}

<AttackCampaign> CLOSED {
    (  $<AttackCampaign_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ? ;
          <x_mitre_domains> [ <https://w3id.org/lmodel/attack/AttackDomainEnum#enterprise-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#mobile-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#ics-attack> ] + ;
          <x_mitre_contributors> @linkml:String * ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ;
          <x_mitre_first_seen_citation> @<CitationString> ;
          <x_mitre_last_seen_citation> @<CitationString> ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:name @linkml:String ;
          stix:description @linkml:String ;
          stix:external_references @stix:ExternalReference + ;
          stix:created_by_ref @stix:StixIdentifier ;
          stix:object_marking_refs @stix:StixIdentifier + ;
          stix:revoked @linkml:Boolean ;
          stix:aliases @linkml:String + ;
          stix:first_seen @linkml:Datetime ;
          stix:last_seen @linkml:Datetime
       ) ;
       rdf:type [ <AttackCampaign> ] ?
    )
}

<AttackIdentity> CLOSED {
    (  $<AttackIdentity_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ? ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:name @linkml:String ;
          stix:object_marking_refs @stix:StixIdentifier + ;
          stix:identity_class @linkml:String ;
          <x_mitre_version> @<AttackVersionString> ;
          stix:description @linkml:String ? ;
          stix:roles @linkml:String * ;
          stix:sectors @linkml:String * ;
          stix:contact_information @linkml:String ?
       ) ;
       rdf:type [ <AttackIdentity> ] ?
    )
}

<AttackKillChainPhase> CLOSED {
    (  $<AttackKillChainPhase_tes> (  &stix:KillChainPhase_tes ;
          rdf:type [ stix:KillChainPhase ] ? ;
          stix:kill_chain_name [ <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-attack>
             <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-mobile-attack>
             <https://w3id.org/lmodel/attack/KillChainNameEnum#mitre-ics-attack> ] ;
          stix:phase_name @linkml:String
       ) ;
       rdf:type [ <AttackKillChainPhase> ] ?
    )
}

<AttackMalware> CLOSED {
    (  $<AttackMalware_tes> (  &<AttackSoftware_tes> ;
          rdf:type [ <AttackSoftware> ] ? ;
          <x_mitre_domains> [ <https://w3id.org/lmodel/attack/AttackDomainEnum#enterprise-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#mobile-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#ics-attack> ] + ;
          <x_mitre_platforms> [ <https://w3id.org/lmodel/attack/AttackPlatformEnum#Windows>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Linux> <https://w3id.org/lmodel/attack/AttackPlatformEnum#macOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Android> <https://w3id.org/lmodel/attack/AttackPlatformEnum#iOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Azure%20AD>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Google%20Workspace>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Office%20Suite>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#SaaS> <https://w3id.org/lmodel/attack/AttackPlatformEnum#IaaS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Containers>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#ESXi>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Identity%20Provider>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Network%20Devices>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#PRE> <https://w3id.org/lmodel/attack/AttackPlatformEnum#None>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Field%20Controller/RTU/PLC/IED>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Data%20Historian>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Engineering%20Workstation>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Control%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Human-Machine%20Interface>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Input/Output%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Safety%20Instrumented%20System/Protection%20Relay>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Embedded> ] * ;
          <x_mitre_contributors> @linkml:String * ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ;
          <x_mitre_aliases> @linkml:String * ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:name @linkml:String ;
          stix:description @linkml:String ;
          stix:external_references @stix:ExternalReference + ;
          stix:created_by_ref @stix:StixIdentifier ;
          stix:is_family @linkml:Boolean ;
          stix:aliases @linkml:String * ;
          stix:malware_types @linkml:String * ;
          stix:kill_chain_phases @<AttackKillChainPhase> * ;
          stix:first_seen @linkml:Datetime ? ;
          stix:last_seen @linkml:Datetime ? ;
          stix:architecture_execution_envs @linkml:String * ;
          stix:implementation_languages @linkml:String * ;
          stix:capabilities @linkml:String *
       ) ;
       rdf:type [ <AttackMalware> ] ?
    )
}

<AttackMarkingDefinition> CLOSED {
    (  $<AttackMarkingDefinition_tes> (  &stix:MarkingDefinition_tes ;
          rdf:type [ stix:MarkingDefinition ] ? ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:spec_version [ <https://w3id.org/lmodel/stix/SpecVersionEnum#2.0> <https://w3id.org/lmodel/stix/SpecVersionEnum#2.1>
             ] ;
          stix:created @linkml:Datetime ;
          stix:created_by_ref @stix:StixIdentifier ;
          stix:definition_type [ <https://w3id.org/lmodel/attack/MarkingDefinitionTypeEnum#tlp>
             <https://w3id.org/lmodel/attack/MarkingDefinitionTypeEnum#statement> ] ;
          stix:definition @linkml:String ;
          stix:name @linkml:String ? ;
          <x_mitre_attack_spec_version> @<SemverString> ;
          <x_mitre_version> @<AttackVersionString> ;
          <x_mitre_deprecated> @linkml:Boolean ?
       ) ;
       rdf:type [ <AttackMarkingDefinition> ] ?
    )
}

<AttackObject>  (
    @<Analytic> OR @<Asset> OR @<AttackCampaign> OR @<AttackIdentity> OR @<AttackRelationship> OR @<AttackSoftware> OR
    @<Collection> OR @<DataComponent> OR @<DataSource> OR @<DetectionStrategy> OR @<Group> OR @<Matrix> OR @<Mitigation> OR
    @<Tactic> OR @<Technique>
)

<AttackObject_struct> {
    (  $<AttackObject_tes> (  &stix:Core_tes ;
          rdf:type [ stix:Core ] ? ;
          <x_mitre_attack_spec_version> @<SemverString> ;
          <x_mitre_version> @<AttackVersionString> ;
          <x_mitre_deprecated> @linkml:Boolean ? ;
          <x_mitre_old_attack_id> @linkml:String ? ;
          stix:id @stix:StixIdentifier ;
          stix:type @stix:StixTypeName ;
          stix:spec_version [ <https://w3id.org/lmodel/stix/SpecVersionEnum#2.0> <https://w3id.org/lmodel/stix/SpecVersionEnum#2.1>
             ] ;
          stix:name @linkml:String ;
          stix:created @linkml:Datetime ;
          stix:modified @linkml:Datetime ;
          stix:created_by_ref @stix:StixIdentifier ?
       ) ;
       rdf:type [ <AttackObject> ] ?
    )
}

stix:AttackPattern CLOSED {
    (  $stix:AttackPattern_tes (  &stix:StixDomainObject_tes ;
          rdf:type [ stix:StixDomainObject ] ? ;
          stix:aliases @linkml:String * ;
          stix:kill_chain_phases @stix:KillChainPhase * ;
          stix:id @stix:StixIdentifier ;
          stix:type @stix:StixTypeName ;
          stix:name @linkml:String
       ) ;
       rdf:type [ stix:AttackPattern ] ?
    )
}

<AttackRelationship> CLOSED {
    (  $<AttackRelationship_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ? ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:relationship_type [ <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#uses>
             <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#mitigates>
             <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#subtechnique-of>
             <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#detects>
             <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#attributed-to>
             <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#targets>
             <https://w3id.org/lmodel/attack/AttackRelationshipTypeEnum#revoked-by> ] ;
          stix:source_ref @stix:StixIdentifier ;
          stix:target_ref @stix:StixIdentifier ;
          stix:description @linkml:String ? ;
          stix:name @linkml:String ? ;
          <x_mitre_version> @<AttackVersionString>
       ) ;
       rdf:type [ <AttackRelationship> ] ?
    )
}

<AttackSoftware>  (
    @<AttackMalware> OR @<AttackTool>
)

<AttackSoftware_struct> {
    (  $<AttackSoftware_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ?
       ) ;
       rdf:type [ <AttackSoftware> ] ?
    )
}

<AttackTool> CLOSED {
    (  $<AttackTool_tes> (  &<AttackSoftware_tes> ;
          rdf:type [ <AttackSoftware> ] ? ;
          <x_mitre_domains> [ <https://w3id.org/lmodel/attack/AttackDomainEnum#enterprise-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#mobile-attack>
             <https://w3id.org/lmodel/attack/AttackDomainEnum#ics-attack> ] + ;
          <x_mitre_platforms> [ <https://w3id.org/lmodel/attack/AttackPlatformEnum#Windows>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Linux> <https://w3id.org/lmodel/attack/AttackPlatformEnum#macOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Android> <https://w3id.org/lmodel/attack/AttackPlatformEnum#iOS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Azure%20AD>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Google%20Workspace>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Office%20Suite>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#SaaS> <https://w3id.org/lmodel/attack/AttackPlatformEnum#IaaS>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Containers>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#ESXi>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Identity%20Provider>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Network%20Devices>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#PRE> <https://w3id.org/lmodel/attack/AttackPlatformEnum#None>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Field%20Controller/RTU/PLC/IED>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Data%20Historian>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Engineering%20Workstation>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Control%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Human-Machine%20Interface>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Input/Output%20Server>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Safety%20Instrumented%20System/Protection%20Relay>
             <https://w3id.org/lmodel/attack/AttackPlatformEnum#Embedded> ] * ;
          <x_mitre_contributors> @linkml:String * ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ;
          <x_mitre_aliases> @linkml:String * ;
          stix:type @stix:StixTypeName ;
          stix:id @stix:StixIdentifier ;
          stix:name @linkml:String ;
          stix:description @linkml:String ;
          stix:external_references @stix:ExternalReference + ;
          stix:created_by_ref @stix:StixIdentifier ;
          stix:aliases @linkml:String * ;
          stix:tool_types @linkml:String * ;
          stix:tool_version @linkml:String ? ;
          stix:kill_chain_phases @<AttackKillChainPhase> *
       ) ;
       rdf:type [ <AttackTool> ] ?
    )
}

stix:AutonomousSystem CLOSED {
    (  $stix:AutonomousSystem_tes (  &stix:CyberObservableObject_tes ;
          rdf:type [ stix:CyberObservableObject ] ? ;
          stix:number @linkml:Integer ;
          stix:rir @linkml:String ? ;
          stix:id @stix:StixIdentifier ;
          stix:type @stix:StixTypeName
       ) ;
       rdf:type [ stix:AutonomousSystem ] ?
    )
}

stix:Bundle  (
    CLOSED {
       (  $stix:Bundle_tes (  &stix:CommonSchemaComponent_tes ;
             rdf:type [ stix:CommonSchemaComponent ] ? ;
             stix:type @stix:StixTypeName ;
             stix:id @stix:StixIdentifier ;
             stix:bundle_objects @stix:StixEntity *
          ) ;
          rdf:type [ stix:Bundle ] ?
       )
    } OR @<AttackBundle>
)

stix:Campaign CLOSED {
    (  $stix:Campaign_tes (  &stix:StixDomainObject_tes ;
          rdf:type [ stix:StixDomainObject ] ? ;
          stix:aliases @linkml:String * ;
          stix:first_seen @linkml:Datetime ? ;
          stix:last_seen @linkml:Datetime ? ;
          stix:objective @linkml:String ? ;
          stix:id @stix:StixIdentifier ;
          stix:type @stix:StixTypeName ;
          stix:name @linkml:String
       ) ;
       rdf:type [ stix:Campaign ] ?
    )
}

<Collection> CLOSED {
    (  $<Collection_tes> (  &<AttackObject_tes> ;
          rdf:type [ <AttackObject> ] ? ;
          <x_mitre_modified_by_ref> @stix:StixIdentifier ? ;
